---
import Button from "./shared/Button.astro";

interface Props {
  colorScheme?: 'blue' | 'purple' | 'yellow' | null;
}

const { colorScheme = null } = Astro.props;

const gradients = {
  blue: 'bg-gradient-to-r from-blue-600 to-blue-800',
  purple: 'bg-gradient-to-r from-purple-600 to-purple-800',
  yellow: 'bg-gradient-to-r from-yellow-600 to-yellow-800',
};

const gradient = colorScheme && colorScheme in gradients
  ? gradients[colorScheme]
  : 'bg-gradient-to-r from-gray-900 via-black to-gray-800';
---

<section class={`py-16 md:py-24 ${gradient}`}>
  <div class="max-w-4xl mx-auto px-4 text-center" data-aos="fade-up" data-aos-delay="100">
    <h2 class="text-3xl md:text-5xl font-main text-white my-2 mb-6">
      ¿Listo para impulsar tu negocio online?
    </h2>
    <p class="text-lg text-white mb-8 max-w-2xl mx-auto">
      Agendemos una llamada de 15 minutos para conocernos, resolver tus dudas y ver cómo podemos trabajar juntos.
    </p>
    <Button href="/contact" label="Agendar una llamada" variant="secondary" {colorScheme} />
  </div>
</section>
