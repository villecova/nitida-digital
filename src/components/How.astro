---
import Badge from "./shared/Badge.astro";
import Button from "./shared/Button.astro";
import LottieIcon from './shared/LottieIcon.svelte';


const steps = [
  {
    icon: '/assets/lottie/chat.json', 
    title: "Hablamos de tu proyecto",
    description: "Nos reunimos para entender tu negocio, objetivos y necesidades.",
  },
  {
    icon: '/assets/lottie/tax.json', 
    title: "Cotizamos y calendarizamos",
    description: "Definimos el alcance del proyecto, presupuesto y tiempos de entrega.",
  },
  {
    icon: '/assets/lottie/design.json', 
    title: "Diseñamos y colaboramos",
    description: "Te presentamos propuestas, iteramos contigo y afinamos hasta lograr un resultado perfecto.",
  },
  {
    icon: '/assets/lottie/thumbs.json', 
    title: "Entregamos con calidad",
    description: "Recibes todos los entregables organizados y listos para usar.",
  },
];
---

<section class="py-16 md:py-24 bg-white" id="how">
  <div class="max-w-6xl mx-auto px-4">
    <div class="text-center mb-12" data-aos="fade-up" data-aos-delay="100">
    <Badge label="Proceso" color="yellow" />
    <h2 class="text-3xl md:text-5xl font-main text-gray-900 my-2">¿Cómo funciona?</h2>
      <p class="text-lg text-accent max-w-2xl mx-auto">Nuestro proceso es sencillo.</p>
    </div>

    <div class="grid gap-8 grid-cols-1 sm:grid-cols-2 lg:grid-cols-4">
      {steps.map((step, index) => (
        <div class="bg-white rounded-2xl p-8 border border-gray-200 shadow-sm hover:shadow-md transition-shadow duration-300 flex flex-col items-center text-center" data-aos="fade-up" data-aos-delay={150 + (index * 50)}>
          <div class="mb-6">
          <LottieIcon client:only="svelte" src={step.icon} />
          </div>
          <h3 class="text-2xl font-bold text-gray-900 mb-3 leading-tight">{step.title}</h3>
          <p class="text-gray-600 text-sm leading-relaxed">{step.description}</p>
        </div>
      ))}
    </div>

    <div class="text-center mt-12">
        <Button href="/works" label="Explorar proyectos " variant="primary" />
    </div>
  </div>
</section>
