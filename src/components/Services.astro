---
import Icon from "./shared/Icon.astro";

const services = [
  { label: "Branding", icon: "star" },
  { label: "Página web", icon: "check" }, 
  { label: "Diseño de logo", icon: "plus" },
  { label: "Diseño Gráfico", icon: "design" },
];
---

<section class="py-20 bg-gray-50 dark:bg-gray-900" id="services">
  <div class="container mx-auto px-4">
    <div class="text-center mb-16">
      <div class="inline-flex items-center px-4 py-2 bg-purple-100 dark:bg-purple-900 text-purple-800 dark:text-purple-200 rounded-full text-sm font-medium mb-4">
        Servicios
      </div>
      <h2 class="text-4xl font-bold text-gray-900 dark:text-white mb-4">
        ¿Qué Ofrecemos?
      </h2>
      <p class="text-xl text-gray-600 dark:text-gray-300 max-w-2xl mx-auto">
        Todo lo que tu marca necesita, en un solo lugar.
      </p>
    </div>
    
    <div class="flex flex-col md:flex-row flex-wrap justify-center gap-4">
      {services.map((service) => (
        <div class="flex items-center gap-3 px-8 py-4 bg-purple-600 hover:bg-purple-700 text-white text-lg font-semibold rounded-2xl transition-colors duration-300 group">
          <Icon name={service.icon} size="6" color="text-white" />
          {service.label}
        </div>
      ))}
    </div>
  </div>
</section>
