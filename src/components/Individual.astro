---
import Button from './shared/Button.astro';

const services = [
  {
    title: 'Logotipo',
    icon: '🎨',
    description: 'Ideal si solo necesitas una identidad base o una renovación puntual.',
  },
  {
    title: 'Sitio web',
    icon: '🌐',
    description: 'Una web funcional para presentar tu marca en línea.',
  },
  {
    title: 'Piezas gráficas',
    icon: '🖼️',
    description: 'Posts, flyers, presentaciones, banners y más.',
  },
];

const { onlySpecialist = false } = Astro.props;
---

<section class="py-16 md:py-24 bg-slate-50">
  <div class="max-w-6xl mx-auto px-4">
    <div class="text-center mb-12">
      <h2 class="text-3xl md:text-5xl font-main text-gray-900 mb-2">¿No necesitas un paquete completo?</h2>
      <p class="text-lg text-accent max-w-2xl mx-auto">
        También puedes contratar servicios por separado, según lo que necesite tu proyecto en este momento.
      </p>
    </div>

    <div class="grid md:grid-cols-3 gap-8 mb-12" data-aos="fade-up" data-aos-delay="100">
      {services.map((service, index) => {
        const iconConfigs = [
          { bg: 'bg-purple-100', color: 'text-purple-600', svg: 'M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z' },
          { bg: 'bg-blue-100', color: 'text-blue-600', svg: 'M9.75 17L9 20l-1 1h8l-1-1-.75-3M3 13h18M5 17h14a2 2 0 002-2V5a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z' },
          { bg: 'bg-yellow-100', color: 'text-yellow-600', svg: 'M7 21h10a2 2 0 002-2V9.414a1 1 0 00-.293-.707l-5.414-5.414A1 1 0 0012.586 3H7a2 2 0 00-2 2v14a2 2 0 002 2z' }
        ];
        const iconConfig = iconConfigs[index] || iconConfigs[0];
        return (
          <div class="bg-white rounded-2xl border border-gray-200 shadow-sm hover:shadow-md transition-shadow duration-300 p-8">
            <div class={`w-16 h-16 ${iconConfig.bg} rounded-xl flex items-center justify-center mb-6`}>
              <svg class={`w-8 h-8 ${iconConfig.color}`} fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d={iconConfig.svg}></path>
              </svg>
            </div>
            <h3 class="text-2xl font-bold text-gray-900 mb-3 leading-tight">{service.title}</h3>
            <p class="text-gray-600 text-sm leading-relaxed">{service.description}</p>
          </div>
        );
      })}
    </div>

    <div class="flex flex-col md:flex-row justify-center gap-4">
      <Button href="mailto:nitidacrea@gmail.com?subject=Solicitud%20de%20cotizaci%C3%B3n&body=Hola%2C%20me%20gustar%C3%ADa%20recibir%20m%C3%A1s%20informaci%C3%B3n.%20Quedo%20atento(a).%20Gracias." label="COTIZAR PROYECTO" variant="primary" fullWidth={false} />

      {onlySpecialist && (
        <Button
          href="/#planes"
          label="Ver más planes"
          variant="secondary"
        />
      )}
    </div>


  </div>
</section>
