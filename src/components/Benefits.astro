---
import LottieIcon from "./shared/LottieIcon.svelte";

const { onlySpecialist = false } = Astro.props;

const generalBenefits = [
  {
    icon: '/assets/lottie/design.json',
    title: "Diseño estratégico",
    description: "Creamos soluciones visuales alineadas con tus objetivos de negocio.",
  },
  {
    icon: '/assets/lottie/time.json',
    title: "Entrega puntual",
    description: "Compromiso con los tiempos de entrega y calidad profesional.",
  },
  {
    icon: '/assets/lottie/tax.json',
    title: "Precios accesibles",
    description: "Diseño de alta calidad a tarifas justas. Ideal para emprendedores y marcas con visión creativa.",
  },
  {
    icon: '/assets/lottie/team.json',
    title: "Equipo profesional",
    description: "Más de 9 años de experiencia en diseño, branding y desarrollo visual.",
  },
  {
    icon: '/assets/lottie/service.json',
    title: "Atención personalizada",
    description: "Acompañamiento en cada etapa del proceso creativo.",
  },
  {
    icon: '/assets/lottie/reload.json',
    title: "Revisiones incluidas",
    description: "Adaptamos y refinamos cada entrega hasta lograr el resultado ideal.",
  },
];

const specialistBenefits = [
  {
    icon: "/assets/lottie/identidad.json",
    title: "Identidad visual profesional",
    description: "Proyecta una identidad visual que refleje tu experiencia y genere confianza.",
  },
  {
    icon: "/assets/lottie/presencia.json",
    title: "Presencia digital efectiva",
    description: "Elementos clave para destacarte en redes, plataformas y buscadores.",
  },
  {
    icon: "/assets/lottie/materiales.json",
    title: "Materiales listos para usar",
    description: "Plantillas, perfiles y formatos editables para tu día a día profesional.",
  },
  {
    icon: "/assets/lottie/alineados.json",
    title: "Alineado a tu especialidad",
    description: "Diseñado para comunicar lo que haces con claridad y coherencia.",
  },
  {
    icon: "/assets/lottie/facilita.json",
    title: "Facilita tu comunicación",
    description: "Incluye firma, hoja de presentación y recursos útiles para consultas o atención.",
  },
  {
    icon: "/assets/lottie/impulsa.json",
    title: "Impulsa tu marca personal",
    description: "Fortalece tu presencia como especialista con un branding profesional.",
  },
];

const benefits = onlySpecialist ? specialistBenefits : generalBenefits;

const title = onlySpecialist
  ? "¿Por qué elegir un plan para profesionistas?"
  : "¿Por qué trabajar con nosotros?";

const subtitle = onlySpecialist
  ? "Una solución pensada para especialistas que quieren destacar con confianza y claridad."
  : "Al elegirnos, obtendrás estas ventajas.";
---

<section class="py-20" id="benefits">
  <div class="container mx-auto px-4">
    <div class="text-center mb-16">
      <div class="inline-flex items-center px-4 py-2 bg-purple-100 dark:bg-purple-900 text-purple-800 dark:text-purple-200 rounded-full text-sm font-medium mb-4">
        Beneficios
      </div>
      <h2 class="text-4xl font-bold text-gray-900 dark:text-white mb-4">
        {title}
      </h2>
      <p class="text-xl text-gray-600 dark:text-gray-300 max-w-2xl mx-auto">
        {subtitle}
      </p>
    </div>

    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-8">
      {benefits.map((benefit) => (
        <div class="bg-white dark:bg-gray-800 rounded-2xl p-8 shadow-lg hover:shadow-xl transition-all duration-300 text-center group">
          <div class="w-20 h-20 bg-purple-100 dark:bg-purple-900 rounded-2xl flex items-center justify-center mx-auto mb-6 group-hover:scale-110 transition-transform duration-300">
            <LottieIcon client:only="svelte" src={benefit.icon} />
          </div>
          <h3 class="text-xl font-bold text-gray-900 dark:text-white mb-4">{benefit.title}</h3>
          <p class="text-gray-600 dark:text-gray-300 text-sm leading-relaxed">{benefit.description}</p>
        </div>
      ))}
    </div>

    <div class="text-center mt-12">
      <a href={onlySpecialist ? "/contact" : "/branding/proyectos"} class="inline-flex items-center px-8 py-4 bg-purple-600 hover:bg-purple-700 text-white font-semibold rounded-xl transition-colors duration-300">
        <svg class="w-5 h-5 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"></path>
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z"></path>
        </svg>
        {onlySpecialist ? "Cotiza tu plan" : "Explorar proyectos"}
      </a>
    </div>
  </div>
</section>
