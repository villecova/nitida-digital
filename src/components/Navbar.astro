---
import Button from "./shared/Button.astro";

const { currentPath } = Astro.props;

const navItems = [
  { label: "Inicio", href: "/home" },
  { label: "Diseño Digital", href: "/design" },
  { label: "Productos Digitales", href: "/digital-products" },
];

const filteredNavItems = navItems.filter(Boolean) as Array<{ label: string; href: string; active?: boolean }>;
---

<nav class="z-50 bg-white border-gray-200 dark:bg-gray-900 fixed top-0 right-0 left-0">
  <div class="max-w-screen-lg flex flex-wrap items-center justify-between mx-auto p-4">
    <a href="/" class="flex items-center space-x-3 rtl:space-x-reverse">
      <img src="/assets/images/hero_logo.svg" class="h-8" alt="Logo" />
    </a>
    <button data-collapse-toggle="navbar-default" type="button" class="inline-flex items-center p-2 w-10 h-10 justify-center text-sm text-gray-500 rounded-lg md:hidden hover:bg-gray-100 focus:outline-none focus:ring-2 focus:ring-gray-200 dark:text-gray-400 dark:hover:bg-gray-700 dark:focus:ring-gray-600" aria-controls="navbar-default" aria-expanded="false">
      <span class="sr-only">Open main menu</span>
      <svg class="w-5 h-5" aria-hidden="true" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 17 14">
        <path stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M1 1h15M1 7h15M1 13h15"/>
      </svg>
    </button>
    <div class="hidden w-full md:block md:w-auto" id="navbar-default">
      <ul class="font-medium flex flex-col align-center  p-4 md:p-0 mt-4 border border-gray-100 rounded-lg bg-gray-50 md:flex-row md:items-center md:space-x-8 rtl:space-x-reverse md:mt-0 md:border-0 md:bg-white dark:bg-gray-800 md:dark:bg-gray-900 dark:border-gray-700">
        {filteredNavItems.map(({ label, href }) => (
          <li>
            <a
              href={href}
              class={`block py-4 px-3 rounded-xl md:p-0
                ${currentPath === href
                  ? currentPath === "/home" 
                    ? "text-black bg-gray-200 md:bg-transparent md:text-black dark:text-white md:dark:text-gray-200"
                    : currentPath === "/digital-products"
                    ? "text-blue-600 bg-blue-100 md:bg-transparent md:text-blue-600 dark:text-white md:dark:text-blue-400"
                    : "text-primary bg-gray-200 md:bg-transparent md:text-primary dark:text-white md:dark:text-purple-400"
                  : currentPath === "/home"
                    ? "text-gray-400 hover:bg-gray-100 md:hover:bg-transparent md:hover:text-black dark:text-white md:dark:hover:text-gray-200 dark:hover:bg-gray-700 dark:hover:text-white md:dark:hover:bg-transparent"
                    : currentPath === "/digital-products"
                    ? "text-gray-400 hover:bg-gray-100 md:hover:bg-transparent md:hover:text-blue-600 dark:text-white md:dark:hover:text-blue-400 dark:hover:bg-gray-700 dark:hover:text-white md:dark:hover:bg-transparent"
                    : "text-gray-400 hover:bg-gray-100 md:hover:bg-transparent md:hover:text-primary dark:text-white md:dark:hover:text-purple-400 dark:hover:bg-gray-700 dark:hover:text-white md:dark:hover:bg-transparent"
              }`}
              aria-current={currentPath === href ? "page" : undefined}
            >
              {label}
            </a>
          </li>
        ))}
        <li>
          {currentPath === "/home" ? (
            <a 
              href="mailto:nitidacrea@gmail.com?subject=Contacto%20desde%20Home&body=Hola%2C%20me%20gustar%C3%ADa%20conocer%20m%C3%A1s%20sobre%20sus%20servicios.%20Gracias."
              class="block w-full bg-gray-900 text-white text-center py-3 px-6 rounded-xl font-semibold hover:bg-gray-800 transition-all duration-300"
            >
              Contactar
            </a>
          ) : currentPath === "/digital-products" ? (
            <a 
              href="mailto:nitidacrea@gmail.com?subject=Contacto%20desde%20Productos%20Digitales&body=Hola%2C%20me%20gustar%C3%ADa%20conocer%20m%C3%A1s%20sobre%20sus%20apps%20y%20servicios.%20Gracias."
              class="block w-full bg-blue-600 text-white text-center py-3 px-6 rounded-xl font-semibold hover:bg-blue-700 transition-all duration-300"
            >
              Contactar
            </a>
          ) : (
            <Button href="/works" label="Proyectos" variant="primary" fullWidth="true" />
          )}
        </li>
      </ul>
    </div>
  </div>
</nav>

<script>
  document.addEventListener('DOMContentLoaded', () => {
    const toggleButton = document.querySelector('[data-collapse-toggle="navbar-default"]') as HTMLButtonElement | null;
    const navLinks = document.querySelectorAll('#navbar-default a[href^="#"], #navbar-default a[href^="/"]');

    navLinks.forEach(link => {
      link.addEventListener('click', () => {
        if (window.innerWidth < 768 && toggleButton?.getAttribute('aria-expanded') === 'true') {
          toggleButton.click(); // Simula el cierre
        }
      });
    });
  });
</script>
