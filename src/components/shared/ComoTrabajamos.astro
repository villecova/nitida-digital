---
interface Props {
  title: string;
  steps: Array<{
    number: number;
    title: string;
    description: string;
  }>;
  colorScheme: 'blue' | 'purple' | 'yellow';
}

const { title, steps, colorScheme } = Astro.props;

const colorClasses = {
  blue: 'text-blue-600',
  purple: 'text-purple-600',
  yellow: 'text-yellow-600'
};

const numberColor = colorClasses[colorScheme];
---

<section class="py-16 md:py-24 bg-slate-50">
  <div class="max-w-6xl mx-auto px-4">
    <div class="text-center mb-12" data-aos="fade-up" data-aos-delay="100">
      <h2 class="text-3xl md:text-5xl font-main text-gray-900 my-2">{title}</h2>
    </div>

    <div class="grid md:grid-cols-4 gap-8">
      {steps.map((step, index) => {
        const bounceClass = `number-bounce-${step.number}`;
        return (
          <div class="text-center" data-aos="fade-up" data-aos-delay={150 + (index * 50)}>
            <div class={`w-16 h-16 bg-white rounded-xl border border-gray-200 flex items-center justify-center mx-auto mb-4 number-bounce ${bounceClass}`}>
              <span class={`text-2xl font-bold ${numberColor}`}>{step.number}</span>
            </div>
            <h3 class="text-xl font-semibold text-gray-900 mb-2">{step.title}</h3>
            <p class="text-gray-600 text-sm">{step.description}</p>
          </div>
        );
      })}
    </div>
  </div>
</section>
