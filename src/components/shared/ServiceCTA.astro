---
import Button from './Button.astro';

interface Props {
  title: string;
  description?: string;
  primaryButtonLabel?: string;
  primaryButtonHref?: string;
  secondaryButtonLabel?: string;
  secondaryButtonHref?: string;
  colorScheme: 'blue' | 'purple' | 'yellow';
}

const { 
  title, 
  description,
  primaryButtonLabel = "Agendar una llamada",
  primaryButtonHref = "/contact",
  secondaryButtonLabel = "Ver planes de servicios",
  secondaryButtonHref = "/planes",
  colorScheme 
} = Astro.props;

const gradients = {
  blue: 'bg-gradient-to-r from-blue-600 to-blue-800',
  purple: 'bg-gradient-to-r from-purple-600 to-purple-800',
  yellow: 'bg-gradient-to-r from-yellow-600 to-yellow-800'
};

const gradient = gradients[colorScheme];
---

<section class={`py-16 md:py-24 ${gradient}`}>
  <div class="max-w-4xl mx-auto px-4 text-center" data-aos="fade-up" data-aos-delay="100">
    <h2 class="text-2xl md:text-4xl font-main text-white my-2 mb-4">
      {title}
    </h2>
    {description && (
      <p class="text-base md:text-lg text-white/80 mb-10 max-w-3xl mx-auto">
        {description}
      </p>
    )}
    <div class="flex flex-col sm:flex-row gap-4 justify-center items-center">
      <Button href={primaryButtonHref} label={primaryButtonLabel} variant="secondary" {colorScheme} />
      <Button href={secondaryButtonHref} label={secondaryButtonLabel} variant="tertiary" {colorScheme} />
    </div>
  </div>
</section>
