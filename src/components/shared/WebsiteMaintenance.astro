---
import Button from './Button.astro';

interface Props {
  title: string;
  intro: string;
  includesLabel: string;
  items: string[];
  benefit: string;
  context: string;
  cta: string;
  trust: string;
  colorScheme: 'blue' | 'purple' | 'yellow';
}

const { title, intro, includesLabel, items, benefit, context, cta, trust, colorScheme } = Astro.props;

const colorClasses = {
  blue: {
    icon: 'text-blue-600',
    border: 'border-blue-100'
  },
  purple: {
    icon: 'text-purple-600',
    border: 'border-purple-100'
  },
  yellow: {
    icon: 'text-yellow-600',
    border: 'border-yellow-100'
  }
};

const colors = colorClasses[colorScheme];
---

<section class="py-16 md:py-24 bg-slate-50">
  <div class="max-w-6xl mx-auto px-4">
    <div class="grid md:grid-cols-2 gap-12 items-center">
      <div data-aos="fade-right" data-aos-delay="100">
        <h2 class="text-3xl md:text-5xl font-main text-gray-900 my-4 mb-6">{title}</h2>
        <p class="text-lg text-gray-700 mb-8 leading-relaxed">
          {intro}
        </p>
        <p class="text-base font-semibold text-gray-900 mb-5">{includesLabel}</p>
        <ul class="space-y-4">
          {items.map((item) => (
            <li class="flex items-start text-gray-700">
              <svg class={`w-4 h-4 ${colors.icon} mr-3 mt-1 flex-shrink-0`} fill="currentColor" viewBox="0 0 20 20">
                <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"></path>
              </svg>
              <span class="text-base leading-relaxed">{item}</span>
            </li>
          ))}
        </ul>
      </div>
      <div class={`bg-white rounded-xl p-8 border ${colors.border} shadow-sm`} data-aos="fade-left" data-aos-delay="200">
        <p class="text-gray-700 mb-6 leading-relaxed">
          {benefit}
        </p>
        <div class="mb-6">
          <p class="text-xs text-gray-500 mb-4 tracking-wide uppercase">{context}</p>
          <Button href="/contact" label={cta} variant="primary" {colorScheme} />
        </div>
        <div class="pt-4 border-t border-gray-100">
          <p class={`text-xs text-gray-500 flex items-center`}>
            <svg class={`w-3 h-3 ${colors.icon} mr-2`} fill="currentColor" viewBox="0 0 20 20">
              <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"></path>
            </svg>
            {trust}
          </p>
        </div>
      </div>
    </div>
  </div>
</section>
