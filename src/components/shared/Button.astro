---
const { 
  href = "#", 
  label = "Click me", 
  variant = "primary", 
  fullWidth = false,
  colorScheme = null
} = Astro.props;

const baseClass = `cursor-pointer uppercase inline-flex items-center justify-center text-base font-medium rounded-lg focus:outline-none transition-all duration-200 ${
  fullWidth ? 'w-full' : ''
}`;

// Paletas de colores por servicio
const colorPalettes = {
  blue: {
    primary: "px-6 py-3 bg-blue-600 text-white hover:bg-black focus:ring-4 focus:ring-blue-500/50",
    secondary: "px-5 py-2.5 bg-white/20 backdrop-blur-sm text-white hover:bg-white hover:text-blue-600 focus:ring-4 focus:ring-white/50",
    tertiary: "px-5 py-2.5 text-white border border-white/80 hover:bg-white hover:text-blue-600 focus:ring-4 focus:ring-white/50"
  },
  purple: {
    primary: "px-6 py-3 bg-purple-600 text-white hover:bg-black focus:ring-4 focus:ring-purple-500/50",
    secondary: "px-5 py-2.5 bg-white/20 backdrop-blur-sm text-white hover:bg-white hover:text-purple-600 focus:ring-4 focus:ring-white/50",
    tertiary: "px-5 py-2.5 text-white border border-white/80 hover:bg-white hover:text-purple-600 focus:ring-4 focus:ring-white/50"
  },
  yellow: {
    primary: "px-6 py-3 bg-yellow-500 text-white hover:bg-black focus:ring-4 focus:ring-yellow-500/50",
    secondary: "px-5 py-2.5 bg-white/20 backdrop-blur-sm text-white hover:bg-white hover:text-yellow-600 focus:ring-4 focus:ring-white/50",
    tertiary: "px-5 py-2.5 text-white border border-white/80 hover:bg-white hover:text-yellow-600 focus:ring-4 focus:ring-white/50"
  }
};

// Variantes por defecto (sin colorScheme)
const defaultVariantClasses = {
  primary: "px-6 py-3 bg-primary text-white hover:bg-black focus:ring-4 focus:ring-primary/50",
  secondary: "px-5 py-2.5 bg-white/20 backdrop-blur-sm text-white hover:bg-white hover:text-primary focus:ring-4 focus:ring-white/50",
  tertiary: "px-5 py-2.5 text-white border border-white/80 hover:bg-white hover:text-primary focus:ring-4 focus:ring-white/50",
  "secondary-hero": "px-5 py-2.5 text-white border border-white/80 hover:bg-white hover:text-primary hover:border-white focus:ring-4 focus:ring-white/50"
};

// Determinar qué clases usar
let variantClasses: Record<string, string>;
if (colorScheme && colorScheme in colorPalettes) {
  const palette = colorPalettes[colorScheme as keyof typeof colorPalettes];
  variantClasses = { ...palette };
  if (variant === "secondary-hero") {
    variantClasses["secondary-hero"] = palette.secondary;
  }
} else {
  variantClasses = defaultVariantClasses;
}

const classes = `${baseClass} ${variantClasses[variant as string] ?? variantClasses.primary}`;
---

<a href={href} class={classes} role="button">
  {label}
</a>
