---
import Button from "./shared/Button.astro";
import IconsGroup from "./shared/IconsGroup.astro";

const {
  type = 'image', // para el fondo: 'image', 'video', 'color'
  overlayColor = 'bg-black/50',
  title = "We invest in the world's potential",
  subtitle = 'Here at Flowbite we focus on markets where tecnología, innovación, and capital can unlock long-term value.',
  primaryButton = 'Agendar una llamada',
  secondaryButton = 'Explorar proyectos',
  primaryLink = '#',
  secondaryLink = '#',
  color = 'bg-primary',
  mediaVariant = 'icons', // 'logo' o 'icon'
  mediaSrc = '/assets/images/nitida_crea.svg', // para logos
  colorScheme = null, // 'blue', 'purple', 'yellow' o null para default
} = Astro.props;
---

<section class={`relative ${type === 'color' ? color : 'bg-[--background] dark:bg-gray-900'} h-dvh pt-16`}>
  {type === 'video' && (
    <div class="absolute inset-0 z-0">
      <video autoplay muted loop playsinline class="w-full h-full object-cover">
        <source src={mediaSrc} type="video/mp4" />
      </video>
      <div class={`absolute inset-0 ${overlayColor}`}></div>
    </div>
  )}

  {type === 'image' && (
    <div class="relative z-10">
      <img src={mediaSrc} alt="Hero Image" class="w-1/2 mx-auto mb-4" />
    </div>
  )}


  <div class='relative mx-auto max-w-screen-lg text-center h-full flex flex-col justify-center p-4'>
    {mediaVariant === 'logo' && (
      <img src={type === 'color' ? '/assets/images/hero_logo-w.svg' : mediaSrc} alt="Hero Image" class="w-3/4 md:w-1/3 mx-auto mb-4" data-aos="fade-up" data-aos-delay="50" />
    )}

    {mediaVariant === 'icons' && (
      <div data-aos="fade-up" data-aos-delay="50">
        <IconsGroup />
      </div>
    )}

    <h1 class={`mb-6 font-main mx-auto text-4xl md:text-6xl lg:text-7xl max-w-4xl ${type === 'color' ? 'text-white' : 'text-gray-900 dark:text-white'}`} data-aos="fade-up" data-aos-delay="100">{title}</h1>
    <p class={`mb-8 text-xl md:text-2xl font-normal max-w-3xl mx-auto ${type === 'color' ? 'text-purple-100' : 'text-accent dark:text-gray-400'}`} data-aos="fade-up" data-aos-delay="150">{subtitle}</p>
    <div class="flex flex-col gap-4 sm:flex-row sm:justify-center sm:space-y-0" data-aos="fade-up" data-aos-delay="200">
      {colorScheme ? (
        <>
          <Button href={primaryLink} label={primaryButton} variant="secondary" colorScheme={colorScheme} />
          <Button href={secondaryLink} label={secondaryButton} variant="tertiary" colorScheme={colorScheme} />
        </>
      ) : (
        <>
          <Button href={primaryLink} label={primaryButton} variant="primary" />
          <Button href={secondaryLink} label={secondaryButton} variant={type === 'color' ? 'secondary-hero' : 'secondary'} />
        </>
      )}
    </div>
  </div>
</section>
