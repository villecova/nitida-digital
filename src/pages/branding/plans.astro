---
import Footer from '../../components/Footer.astro';
import Navbar from '../../components/Navbar.astro';
import Princing from '../../components/Princing.astro';
import Layout from '../../layouts/Layout.astro';

const pageTitle = "Planes de Branding - Identidad Visual Profesional | Nítida Digital";
const pageDescription = "Explora nuestros planes de servicios para Branding. Elige el paquete que mejor se adapta a tu proyecto de identidad visual.";
const pageUrl = "https://nitidadigital.com/branding/plans";
const imageUrl = "https://nitidadigital.com/assets/images/og_image.png";
---

<Layout pageTitle={pageTitle} pageDescription={pageDescription} pageUrl={pageUrl} imageUrl={imageUrl}>
	<Navbar currentPath="/branding/plans" />
	
	<div class="pt-16">
		<Princing colorScheme="purple" backLink="/branding" backLabel="Volver a Branding" />
	</div>

	<Footer />
</Layout>
