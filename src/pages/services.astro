---
import Benefits from '../components/Benefits.astro';
import Contact from '../components/Contact.astro';
import Footer from '../components/Footer.astro';
import Navbar from '../components/Navbar.astro';
import Princing from '../components/Princing.astro';
import Badge from '../components/shared/Badge.astro';
import Button from '../components/shared/Button.astro';
import Welcome from '../components/Welcome.astro';
import Layout from '../layouts/Layout.astro';

const pageTitle = "Servicios - Web Design, Branding y Productos Digitales | Nítida Digital";
const pageDescription = "Servicios de diseño y desarrollo web, branding estratégico y productos digitales. Web Design & Development es nuestro servicio principal para negocios.";
const pageUrl = "https://nitidadigital.com/services";
const imageUrl = "https://nitidadigital.com/assets/images/og_image.png";
---

<Layout pageTitle={pageTitle} pageDescription={pageDescription} pageUrl={pageUrl} imageUrl={imageUrl}>
	<Navbar currentPath="/services" />
	
	<Welcome 
		type="color"
		color="bg-gradient-to-r from-purple-900 via-purple-800 to-purple-700"
		title="Servicios diseñados para impulsar tu negocio"
		subtitle="Web Design & Development lidera nuestro portafolio, acompañado de Branding estratégico y Productos Digitales."
		primaryButton="Agendar una llamada"
		primaryLink="mailto:nitidacrea@gmail.com?subject=Solicitud%20para%20agendar%20una%20llamada&body=Hola%2C%20me%20gustar%C3%ADa%20agendar%20una%20llamada%20para%20conocer%20m%C3%A1s%20sobre%20sus%20servicios.%20%C2%BFCu%C3%A1ndo%20podr%C3%ADamos%20agendarla%3F%20Gracias."
		secondaryButton="Ver servicios"
		secondaryLink="/services"
		mediaVariant="logo"
	/>

	<!-- Web Design & Development - Principal -->
	<section class="py-16 md:py-24 bg-white" id="web">
		<div class="max-w-6xl mx-auto px-4">
			<div class="text-center mb-12" data-aos="fade-up" data-aos-delay="100">
				<Badge label="Servicio Principal" color="yellow" />
				<h2 class="text-3xl md:text-5xl font-main text-gray-900 my-2">Web Design & Development</h2>
				<p class="text-lg text-accent max-w-3xl mx-auto">
					Sitios web profesionales, responsivos y optimizados que convierten visitantes en clientes. Nuestro servicio principal para negocios que buscan presencia digital efectiva.
				</p>
			</div>

			<div class="grid md:grid-cols-2 gap-12 items-center mb-16">
				<div data-aos="fade-right" data-aos-delay="150">
					<h3 class="text-2xl font-bold text-gray-900 mb-4">¿Qué incluye?</h3>
					<ul class="space-y-4">
						<li class="flex items-start">
							<svg class="w-6 h-6 text-green-500 mr-3 mt-1 flex-shrink-0" fill="currentColor" viewBox="0 0 20 20">
								<path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"></path>
							</svg>
							<div>
								<strong class="text-gray-900">Diseño responsivo</strong>
								<p class="text-gray-600 text-sm">Sitios que se ven perfectos en todos los dispositivos</p>
							</div>
						</li>
						<li class="flex items-start">
							<svg class="w-6 h-6 text-green-500 mr-3 mt-1 flex-shrink-0" fill="currentColor" viewBox="0 0 20 20">
								<path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"></path>
							</svg>
							<div>
								<strong class="text-gray-900">Optimización SEO</strong>
								<p class="text-gray-600 text-sm">Tu sitio aparece en los resultados de búsqueda</p>
							</div>
						</li>
						<li class="flex items-start">
							<svg class="w-6 h-6 text-green-500 mr-3 mt-1 flex-shrink-0" fill="currentColor" viewBox="0 0 20 20">
								<path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"></path>
							</svg>
							<div>
								<strong class="text-gray-900">Landing pages y e-commerce</strong>
								<p class="text-gray-600 text-sm">Páginas que convierten y tiendas online funcionales</p>
							</div>
						</li>
						<li class="flex items-start">
							<svg class="w-6 h-6 text-green-500 mr-3 mt-1 flex-shrink-0" fill="currentColor" viewBox="0 0 20 20">
								<path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"></path>
							</svg>
							<div>
								<strong class="text-gray-900">Velocidad y rendimiento</strong>
								<p class="text-gray-600 text-sm">Sitios rápidos que mejoran la experiencia del usuario</p>
							</div>
						</li>
					</ul>
				</div>
				<div class="bg-gradient-to-br from-purple-600 to-purple-800 rounded-2xl p-8 text-white" data-aos="fade-left" data-aos-delay="200">
					<h3 class="text-2xl font-bold mb-4">Ideal para:</h3>
					<ul class="space-y-3">
						<li class="flex items-center">
							<svg class="w-5 h-5 text-green-300 mr-3" fill="currentColor" viewBox="0 0 20 20">
								<path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"></path>
							</svg>
							Negocios que necesitan presencia digital profesional
						</li>
						<li class="flex items-center">
							<svg class="w-5 h-5 text-green-300 mr-3" fill="currentColor" viewBox="0 0 20 20">
								<path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"></path>
							</svg>
							Emprendedores que quieren escalar su negocio
						</li>
						<li class="flex items-center">
							<svg class="w-5 h-5 text-green-300 mr-3" fill="currentColor" viewBox="0 0 20 20">
								<path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"></path>
							</svg>
							Marcas que buscan aumentar sus conversiones
						</li>
						<li class="flex items-center">
							<svg class="w-5 h-5 text-green-300 mr-3" fill="currentColor" viewBox="0 0 20 20">
								<path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"></path>
							</svg>
							Empresas que necesitan renovar su sitio web
						</li>
					</ul>
					<div class="mt-8">
						<Button href="/contact" label="Cotizar proyecto web" variant="primary" />
					</div>
				</div>
			</div>
		</div>
	</section>

	<!-- Branding & Graphic Design -->
	<section class="py-16 md:py-24 bg-slate-50" id="branding">
		<div class="max-w-6xl mx-auto px-4">
			<div class="text-center mb-12" data-aos="fade-up" data-aos-delay="100">
				<Badge label="Servicio Complementario" color="yellow" />
				<h2 class="text-3xl md:text-5xl font-main text-gray-900 my-2">Branding & Graphic Design</h2>
				<p class="text-lg text-accent max-w-3xl mx-auto">
					Identidad visual completa que comunica tu propuesta de valor y diferencia tu marca en el mercado.
				</p>
			</div>

			<div class="grid md:grid-cols-2 gap-12 items-center">
				<div class="bg-white rounded-2xl p-8 shadow-lg" data-aos="fade-right" data-aos-delay="150">
					<h3 class="text-2xl font-bold text-gray-900 mb-4">¿Qué incluye?</h3>
					<ul class="space-y-4">
						<li class="flex items-start">
							<svg class="w-6 h-6 text-green-500 mr-3 mt-1 flex-shrink-0" fill="currentColor" viewBox="0 0 20 20">
								<path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"></path>
							</svg>
							<div>
								<strong class="text-gray-900">Identidad visual completa</strong>
								<p class="text-gray-600 text-sm">Logotipo, paleta de colores, tipografía y elementos gráficos</p>
							</div>
						</li>
						<li class="flex items-start">
							<svg class="w-6 h-6 text-green-500 mr-3 mt-1 flex-shrink-0" fill="currentColor" viewBox="0 0 20 20">
								<path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"></path>
							</svg>
							<div>
								<strong class="text-gray-900">Manual de marca</strong>
								<p class="text-gray-600 text-sm">Guía completa para mantener la coherencia visual</p>
							</div>
						</li>
						<li class="flex items-start">
							<svg class="w-6 h-6 text-green-500 mr-3 mt-1 flex-shrink-0" fill="currentColor" viewBox="0 0 20 20">
								<path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"></path>
							</svg>
							<div>
								<strong class="text-gray-900">Diseño gráfico estratégico</strong>
								<p class="text-gray-600 text-sm">Materiales de marketing y comunicación visual</p>
							</div>
						</li>
						<li class="flex items-start">
							<svg class="w-6 h-6 text-green-500 mr-3 mt-1 flex-shrink-0" fill="currentColor" viewBox="0 0 20 20">
								<path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"></path>
							</svg>
							<div>
								<strong class="text-gray-900">Aplicación de marca</strong>
								<p class="text-gray-600 text-sm">Tarjetas, papelería, redes sociales y más</p>
							</div>
						</li>
					</ul>
				</div>
				<div data-aos="fade-left" data-aos-delay="200">
					<h3 class="text-2xl font-bold text-gray-900 mb-4">Ideal para:</h3>
					<ul class="space-y-3 mb-8">
						<li class="flex items-center text-gray-700">
							<svg class="w-5 h-5 text-green-500 mr-3" fill="currentColor" viewBox="0 0 20 20">
								<path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"></path>
							</svg>
							Marcas nuevas que necesitan identidad desde cero
						</li>
						<li class="flex items-center text-gray-700">
							<svg class="w-5 h-5 text-green-500 mr-3" fill="currentColor" viewBox="0 0 20 20">
								<path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"></path>
							</svg>
							Negocios que buscan renovar su imagen
						</li>
						<li class="flex items-center text-gray-700">
							<svg class="w-5 h-5 text-green-500 mr-3" fill="currentColor" viewBox="0 0 20 20">
								<path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"></path>
							</svg>
							Empresas que quieren diferenciarse
						</li>
					</ul>
					<Button href="/contact" label="Cotizar branding" variant="primary" />
				</div>
			</div>
		</div>
	</section>

	<!-- Digital Products -->
	<section class="py-16 md:py-24 bg-white" id="digital-products">
		<div class="max-w-6xl mx-auto px-4">
			<div class="text-center mb-12" data-aos="fade-up" data-aos-delay="100">
				<Badge label="Servicio Complementario" color="yellow" />
				<h2 class="text-3xl md:text-5xl font-main text-gray-900 my-2">Digital Products</h2>
				<p class="text-lg text-accent max-w-3xl mx-auto">
					Aplicaciones móviles y productos digitales que resuelven problemas reales y mejoran la experiencia de los usuarios.
				</p>
			</div>

			<div class="grid md:grid-cols-2 gap-12 items-center">
				<div data-aos="fade-right" data-aos-delay="150">
					<h3 class="text-2xl font-bold text-gray-900 mb-4">¿Qué incluye?</h3>
					<ul class="space-y-4">
						<li class="flex items-start">
							<svg class="w-6 h-6 text-green-500 mr-3 mt-1 flex-shrink-0" fill="currentColor" viewBox="0 0 20 20">
								<path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"></path>
							</svg>
							<div>
								<strong class="text-gray-900">Apps móviles nativas</strong>
								<p class="text-gray-600 text-sm">Aplicaciones para iOS y Android</p>
							</div>
						</li>
						<li class="flex items-start">
							<svg class="w-6 h-6 text-green-500 mr-3 mt-1 flex-shrink-0" fill="currentColor" viewBox="0 0 20 20">
								<path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"></path>
							</svg>
							<div>
								<strong class="text-gray-900">Publicación en tiendas</strong>
								<p class="text-gray-600 text-sm">App Store y Google Play</p>
							</div>
						</li>
						<li class="flex items-start">
							<svg class="w-6 h-6 text-green-500 mr-3 mt-1 flex-shrink-0" fill="currentColor" viewBox="0 0 20 20">
								<path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"></path>
							</svg>
							<div>
								<strong class="text-gray-900">Diseño UX/UI</strong>
								<p class="text-gray-600 text-sm">Experiencias de usuario intuitivas y atractivas</p>
							</div>
						</li>
						<li class="flex items-start">
							<svg class="w-6 h-6 text-green-500 mr-3 mt-1 flex-shrink-0" fill="currentColor" viewBox="0 0 20 20">
								<path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"></path>
							</svg>
							<div>
								<strong class="text-gray-900">Mantenimiento y actualizaciones</strong>
								<p class="text-gray-600 text-sm">Soporte continuo para tu producto digital</p>
							</div>
						</li>
					</ul>
				</div>
				<div class="bg-blue-50 rounded-2xl p-8 border-2 border-blue-200" data-aos="fade-left" data-aos-delay="200">
					<h3 class="text-2xl font-bold text-gray-900 mb-4">Ideal para:</h3>
					<ul class="space-y-3 mb-8">
						<li class="flex items-center text-gray-700">
							<svg class="w-5 h-5 text-green-500 mr-3" fill="currentColor" viewBox="0 0 20 20">
								<path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"></path>
							</svg>
							Negocios que necesitan una app móvil
						</li>
						<li class="flex items-center text-gray-700">
							<svg class="w-5 h-5 text-green-500 mr-3" fill="currentColor" viewBox="0 0 20 20">
								<path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"></path>
							</svg>
							Startups con ideas innovadoras
						</li>
						<li class="flex items-center text-gray-700">
							<svg class="w-5 h-5 text-green-500 mr-3" fill="currentColor" viewBox="0 0 20 20">
								<path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"></path>
							</svg>
							Empresas que buscan digitalizar procesos
						</li>
					</ul>
					<div class="flex gap-4">
						<Button href="/digital-products" label="Ver productos" variant="primary" />
						<Button href="/contact" label="Cotizar app" variant="secondary" />
					</div>
				</div>
			</div>
		</div>
	</section>

	<!-- Beneficios -->
	<Benefits />

	<!-- Precios -->
	<Princing />

	<!-- Contacto -->
	<Contact />

	<Footer />
</Layout>
