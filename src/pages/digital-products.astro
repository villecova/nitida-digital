---
import Footer from '../components/Footer.astro';
import Navbar from '../components/Navbar.astro';
import Welcome from '../components/Welcome.astro';
import Layout from '../layouts/Layout.astro';

const pageTitle = "Apps Móviles y Productos Digitales | Nítida Digital";
const pageDescription = "Descubre nuestras aplicaciones móviles: Cosmos Plant Care, Gym Partner y Nutripill. Apps innovadoras disponibles próximamente en App Store y Google Play.";
const pageUrl = "https://nitidadigital.com/digital-products";
const imageUrl = "https://nitidadigital.com/assets/images/og_image.png";

// Datos de las apps
const apps = [
	{
		id: 1,
		name: "Cosmos Plant Care",
		description: "No más plantas olvidadas. Recordatorios de riego y fertilización para mantener tus plantas siempre saludables.",
		image: "/assets/store/cosmos-1.png",
		appleStore: "https://apps.apple.com",
		googlePlay: "https://play.google.com",
		price: "Gratis"
	},
	{
		id: 2,
		name: "Gym Partner", 
		description: "Tu compañero perfecto para el gimnasio. Planifica rutinas, rastrea progreso y alcanza tus objetivos fitness.",
		image: "/assets/store/gym-2.png",
		appleStore: "https://apps.apple.com",
		googlePlay: "https://play.google.com",
		price: "Gratis"
	},
	{
		id: 3,
		name: "Nutripill",
		description: "Controla tu nutrición y recordatorios de suplementos. Lleva un seguimiento de tu bienestar y hábitos saludables.",
		image: "/assets/store/cosmos-1.png",
		appleStore: "https://apps.apple.com",
		googlePlay: "https://play.google.com",
		price: "Gratis"
	}
];
---

<Layout pageTitle={pageTitle} pageDescription={pageDescription} pageUrl={pageUrl} imageUrl={imageUrl}>
	<Navbar currentPath="/digital-products" />
	
	<Welcome 
		type="color"
		color="bg-gradient-to-br from-yellow-600 via-yellow-500 to-yellow-400"
		title="Digital Products"
		subtitle="Ready-to-use digital resources designed to save time and bring clarity to your projects."
		primaryButton="Explore products"
		primaryLink="#products"
		secondaryButton=""
		secondaryLink=""
		mediaVariant="logo"
		colorScheme="yellow"
	/>

		<!-- Apps Section -->
		<section id="apps" class="py-32 bg-gray-50">
			<div class="max-w-6xl mx-auto px-4">
				<!-- Section Header -->
				<div class="text-center mb-20" data-aos="fade-up" data-aos-delay="50">
					<h2 class="text-4xl font-bold text-gray-900 mb-4 font-main">Nuestras Apps</h2>
					<p class="text-xl text-gray-600 font-primary">
						Aplicaciones móviles diseñadas para mejorar tu experiencia diaria
					</p>
				</div>
				
				<!-- Apps Grid -->
				<div class="grid md:grid-cols-3 gap-6 max-w-5xl mx-auto">
				{apps.map((app, index) => (
					<div class="bg-white rounded-2xl p-8 border-2 border-gray-200 shadow-lg hover:shadow-xl transition-all duration-300 hover:-translate-y-2" data-aos="fade-up" data-aos-delay={100 + (index * 100)}>
						<!-- App Info -->
						<div class="text-center mb-6">
							<h3 class="text-3xl font-bold text-gray-900 mb-3 font-main">{app.name}</h3>
							<span class="inline-block bg-yellow-100 text-yellow-800 px-3 py-1 rounded-full text-sm font-semibold mb-4">
								Próximamente
							</span>
						</div>
						
						<!-- App Image -->
						<div class="mb-4 mt-8 mx-auto" style="width: 40%;">
							{app.name === "Nutripill" ? (
								<div class="w-full aspect-[425/856] rounded-xl bg-gray-200 flex items-center justify-center" aria-hidden="true">
									<span class="text-gray-400 text-4xl">💊</span>
								</div>
							) : (
								<img src={app.image} alt={app.name} class="w-full h-auto" />
							)}
						</div>
						
						<!-- App Description -->
						<div class="text-center mb-6">
							<p class="text-gray-600 text-sm">{app.description}</p>
						</div>
						
						<!-- Download Buttons -->
						<div class="flex gap-2 items-start mt-6 opacity-50">
							<div class="flex-1 relative group">
								<img src="/assets/store/ios.svg" alt="Download on the App Store" class="w-full h-8 object-contain" />
								<div class="absolute bottom-full left-1/2 transform -translate-x-1/2 mb-2 px-3 py-1 bg-gray-800 text-white text-sm rounded-lg opacity-0 group-hover:opacity-100 transition-opacity duration-300 pointer-events-none whitespace-nowrap">
									Próximamente
									<div class="absolute top-full left-1/2 transform -translate-x-1/2 w-0 h-0 border-l-4 border-r-4 border-t-4 border-transparent border-t-gray-800"></div>
								</div>
							</div>
							<div class="flex-1 relative group">
								<img src="/assets/store/md.png" alt="Get it on Google Play" class="w-full h-8 object-contain" />
								<div class="absolute bottom-full left-1/2 transform -translate-x-1/2 mb-2 px-3 py-1 bg-gray-800 text-white text-sm rounded-lg opacity-0 group-hover:opacity-100 transition-opacity duration-300 pointer-events-none whitespace-nowrap">
									Próximamente
									<div class="absolute top-full left-1/2 transform -translate-x-1/2 w-0 h-0 border-l-4 border-r-4 border-t-4 border-transparent border-t-gray-800"></div>
								</div>
							</div>
						</div>
						
						<!-- Terms Link -->
						<div class="mt-8 text-center">
							{app.name === "Cosmos Plant Care" ? (
								<a href="/digital-products/cosmos/term-cosmos" class="text-gray-400 hover:text-gray-600 text-[10px]">
									Términos y Condiciones
								</a>
							) : app.name === "Nutripill" ? (
								<a href="/digital-products/nutripill/term-nutripill" class="text-gray-400 hover:text-gray-600 text-[10px]">
									Términos y Condiciones
								</a>
							) : (
								<span class="text-gray-300 cursor-not-allowed text-[10px]">
									Términos y Condiciones
								</span>
							)}
						</div>
					</div>
				))}
			</div>
		</div>
	</section>

	<Footer hideTerms={true} hideSocial={true} />
</Layout>
