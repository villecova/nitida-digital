---
import Footer from '../components/Footer.astro';
import Navbar from '../components/Navbar.astro';
import Layout from '../layouts/Layout.astro';

const pageTitle = "Nítida Digital - Diseño y Desarrollo de Apps | Inicio";
const pageDescription = "Descubre Nítida Digital: especialistas en diseño de marca, páginas web y desarrollo de aplicaciones móviles. Todo lo que tu proyecto necesita en un solo lugar.";
const pageUrl = "https://nitidadigital.com/home";
const imageUrl = "https://nitidadigital.com/assets/images/og_image.png";
---

<Layout pageTitle={pageTitle} pageDescription={pageDescription} pageUrl={pageUrl} imageUrl={imageUrl}>
	<Navbar currentPath="/home" />
	<main class="min-h-screen bg-gradient-to-r from-gray-900 via-black to-gray-800 pt-16">
		<div class="w-full px-4 py-16">
			<!-- Header -->
			<div class="text-center mb-10">
				<div class="mb-8">
					<img src="/assets/images/hero_logo-w.svg" class="h-12 md:h-20 mx-auto" alt="Nitida Digital Logo" />
				</div>
				<p class="text-xl text-white max-w-2xl mx-auto">
					Diseñamos tu marca y también creamos apps para tu día a día. Descubre todo lo que tenemos para ti.
				</p>
			</div>

			<!-- Cards Container -->
			<div class="grid md:grid-cols-2 gap-6 max-w-3xl mx-auto">
				<!-- Diseño Digital Card -->
				<div class="group relative bg-white rounded-2xl shadow-xl hover:shadow-2xl transition-all duration-300 transform hover:-translate-y-2 flex flex-col">
					<div class="p-6 flex flex-col flex-grow">
						<!-- Icon -->
						<div class="w-12 h-12 bg-purple-100 rounded-xl flex items-center justify-center mb-4 group-hover:scale-110 transition-transform duration-300">
							<svg class="w-6 h-6 text-purple-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
								<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M7 21a4 4 0 01-4-4V5a2 2 0 012-2h4a2 2 0 012 2v12a4 4 0 01-4 4zM21 5a2 2 0 00-2-2h-4a2 2 0 00-2 2v12a4 4 0 004 4h4a2 2 0 002-2V5z"></path>
							</svg>
						</div>

						<!-- Content -->
						<h2 class="text-xl font-bold text-gray-900 mb-3">
							Diseño Digital
						</h2>
						<p class="text-gray-600 mb-6 flex-grow text-sm">
							Identidad visual completa, diseño gráfico estratégico, branding profesional y páginas web para tu marca.
						</p>

						<!-- Features -->
						<ul class="space-y-1 mb-6">
							<li class="flex items-center text-gray-600 text-sm">
								<svg class="w-4 h-4 text-green-500 mr-2" fill="currentColor" viewBox="0 0 20 20">
									<path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"></path>
								</svg>
								Identidad visual
							</li>
							<li class="flex items-center text-gray-600 text-sm">
								<svg class="w-4 h-4 text-green-500 mr-2" fill="currentColor" viewBox="0 0 20 20">
									<path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"></path>
								</svg>
								Páginas web
							</li>
							<li class="flex items-center text-gray-600 text-sm">
								<svg class="w-4 h-4 text-green-500 mr-2" fill="currentColor" viewBox="0 0 20 20">
									<path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"></path>
								</svg>
								Branding estratégico
							</li>
						</ul>
					</div>

					<!-- Button -->
					<div class="p-6 pt-0">
						<a href="/design" class="block w-full bg-purple-600 hover:bg-purple-700 text-white font-semibold py-2 px-4 rounded-xl text-center transition-colors duration-300 text-sm">
							Explorar Diseño Digital
						</a>
					</div>
				</div>

				<!-- Productos Digitales Card -->
				<div class="group relative bg-white rounded-2xl shadow-xl hover:shadow-2xl transition-all duration-300 transform hover:-translate-y-2 flex flex-col">
					<div class="p-6 flex flex-col flex-grow">
						<!-- Icon -->
						<div class="w-12 h-12 bg-blue-100 rounded-xl flex items-center justify-center mb-4 group-hover:scale-110 transition-transform duration-300">
							<svg class="w-6 h-6 text-blue-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
								<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 18h.01M8 21h8a2 2 0 002-2V5a2 2 0 00-2-2H8a2 2 0 00-2 2v14a2 2 0 002 2z"></path>
							</svg>
						</div>

						<!-- Content -->
						<h2 class="text-xl font-bold text-gray-900 mb-3">
							Productos Digitales
						</h2>
						<p class="text-gray-600 mb-4 flex-grow text-sm">
							Descubre nuestras apps en App Store y Google Play. ¡Descárgalas hoy mismo!
						</p>

						<!-- Features -->
						<ul class="space-y-1 mb-6">
							<li class="flex items-center text-gray-600 text-sm">
								<svg class="w-4 h-4 text-green-500 mr-2" fill="currentColor" viewBox="0 0 20 20">
									<path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"></path>
								</svg>
								Apps móviles
							</li>
							<li class="flex items-center text-gray-600 text-sm">
								<svg class="w-4 h-4 text-green-500 mr-2" fill="currentColor" viewBox="0 0 20 20">
									<path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"></path>
								</svg>
								Disponibles en tiendas
							</li>
							<li class="flex items-center text-gray-600 text-sm">
								<svg class="w-4 h-4 text-green-500 mr-2" fill="currentColor" viewBox="0 0 20 20">
									<path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"></path>
								</svg>
								Descarga directa
							</li>
						</ul>
					</div>

					<!-- Button -->
					<div class="p-6 pt-0">
						<a href="/digital-products" class="block w-full bg-blue-600 hover:bg-blue-700 text-white font-semibold py-2 px-4 rounded-xl text-center transition-colors duration-300 text-sm">
							Ver Productos
						</a>
					</div>
				</div>
			</div>
		</div>
	</main>

	<Footer />
</Layout>
