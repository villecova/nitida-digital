---
import { getCollection } from 'astro:content';
import Footer from '../components/Footer.astro';
import Navbar from '../components/Navbar.astro';
import ComoTrabajamos from '../components/shared/ComoTrabajamos.astro';
import IdealPara from '../components/shared/IdealPara.astro';
import QueObtienes from '../components/shared/QueObtienes.astro';
import ServiceCTA from '../components/shared/ServiceCTA.astro';
import ServicePortfolio from '../components/shared/ServicePortfolio.astro';
import WebsiteMaintenance from '../components/shared/WebsiteMaintenance.astro';
import Welcome from '../components/Welcome.astro';
import { es } from '../i18n/es';
import Layout from '../layouts/Layout.astro';

const pageTitle = "Web Design & Development - Sitios Web Profesionales | Nítida Digital";
const pageDescription = "Sitios web profesionales, responsivos y optimizados que convierten visitantes en clientes. Diseño y desarrollo web para negocios.";
const pageUrl = "https://nitidadigital.com/web-design";
const imageUrl = "https://nitidadigital.com/assets/images/og_image.png";

// Filtrar proyectos de web
const allEntries = await getCollection('work');
const webProjects = allEntries.filter(entry => 
  entry.data.scope?.toLowerCase().includes('página web') || 
  entry.data.scope?.toLowerCase().includes('web') ||
  entry.data.scope?.toLowerCase().includes('sitio')
);

const projects = webProjects
  .map((entry) => ({
    slug: entry.slug,
    title: entry.data.title,
    gallery: entry.data.gallery || [],
    year: entry.data.year,
  }))
  .sort((a, b) => b.year - a.year);

const t = es.webDesign;
---

<Layout pageTitle={pageTitle} pageDescription={pageDescription} pageUrl={pageUrl} imageUrl={imageUrl}>
	<Navbar currentPath="/web-design" />
	
	<Welcome 
		type="color"
		color="bg-gradient-to-r from-blue-900 via-blue-800 to-blue-700"
		title={t.hero.title}
		subtitle={t.hero.subtitle}
		primaryButton={t.hero.primaryButton}
		primaryLink="/contact"
		secondaryButton={t.hero.secondaryButton}
		secondaryLink="#portafolio"
		mediaVariant="logo"
		colorScheme="blue"
	/>

	<IdealPara 
		title={t.idealFor.title}
		plansLink="/planes?service=web"
		items={t.idealFor.items.map(item => ({ iconPath: item.icon, title: item.title, description: item.description }))}
		colorScheme="blue"
	/>

	<QueObtienes 
		title={t.whatYouGet.title}
		intro={t.whatYouGet.intro}
		examples={t.whatYouGet.examples}
		plansLink="/planes?service=web"
		items={t.whatYouGet.items.map(item => ({ iconPath: item.icon, title: item.title, description: item.description }))}
		colorScheme="blue"
	/>

	<ComoTrabajamos 
		title={t.howWeWork.title}
		steps={t.howWeWork.steps}
		colorScheme="blue"
	/>

	<ServicePortfolio 
		title={t.portfolio.title}
		subtitle={t.portfolio.subtitle}
		emptyMessage={t.portfolio.empty}
		plansLink="/planes?service=web"
		{projects}
		colorScheme="blue"
	/>

	<WebsiteMaintenance 
		title={t.maintenance.title}
		intro={t.maintenance.intro}
		includesLabel={t.maintenance.includesLabel}
		items={t.maintenance.items}
		benefit={t.maintenance.benefit}
		context={t.maintenance.context}
		cta={t.maintenance.cta}
		trust={t.maintenance.trust}
		colorScheme="blue"
	/>

	<ServiceCTA 
		title={t.cta.title}
		description={t.cta.description}
		primaryButtonLabel={t.cta.primaryButton}
		primaryButtonHref="/contact"
		secondaryButtonLabel={t.cta.secondaryButton}
		secondaryButtonHref="/planes?service=web"
		colorScheme="blue"
	/>

	<Footer />
</Layout>
