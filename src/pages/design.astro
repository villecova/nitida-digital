---
import Benefits from '../components/Benefits.astro';
import Contact from '../components/Contact.astro';
import Faqs from '../components/Faqs.astro';
import Footer from '../components/Footer.astro';
import Gallery from '../components/Gallery.astro';
import How from '../components/How.astro';
import Individual from '../components/Individual.astro';
import Navbar from '../components/Navbar.astro';
import Princing from '../components/Princing.astro';
import Services from '../components/Services.astro';
import Welcome from '../components/Welcome.astro';
import Layout from '../layouts/Layout.astro';

const pageTitle = "Diseño Digital y Branding Profesional | Nítida Digital";
const pageDescription = "Servicios de diseño digital, branding estratégico, identidad visual y páginas web profesionales. Creamos marcas memorables que conectan con tu audiencia.";
const pageUrl = "https://nitidadigital.com/design";
const imageUrl = "https://nitidadigital.com/assets/images/og_image.png";
---

<Layout pageTitle={pageTitle} pageDescription={pageDescription} pageUrl={pageUrl} imageUrl={imageUrl}>
	<Navbar currentPath="/design" />
	<Welcome 
		type="color"
		color="bg-gradient-to-r from-purple-900 via-purple-800 to-purple-700"
		title="Todo lo que tu marca necesita, en un solo lugar"
		subtitle="Diseño y branding estratégico, profesional y hecho por expertos, adaptado a las necesidades de tu proyecto."
		primaryLabel="Agendar una llamada"
		primaryLink="mailto:nitidacrea@gmail.com?subject=Solicitud%20para%20agendar%20una%20llamada&body=Hola%2C%20me%20gustar%C3%ADa%20agendar%20una%20llamada%20para%20conocer%20m%C3%A1s%20sobre%20sus%20servicios.%20%C2%BFCu%C3%A1ndo%20podr%C3%ADamos%20agendarla%3F%20Gracias."
		secondaryLabel="Explorar proyectos"
		secondaryLink="/works"
		mediaVariant="logo"
	/>
	<Gallery  />
	<How  />
	<Benefits  />
	<Services  />
	<Princing  />
	<Individual  />
	<Faqs  />
	<Contact  />
	<Footer  />
</Layout>
