---
import Contact from '../components/Contact.astro';
import Footer from '../components/Footer.astro';
import Layout from '../layouts/Layout.astro';

// Datos de las aplicaciones - puedes agregar más aquí
const apps = [
  {
    id: 1,
    name: "App Ejemplo 1",
    description: "Una aplicación móvil innovadora que simplifica tu día a día con funcionalidades únicas.",
    category: "Productividad",
    icon: "📱",
    features: ["Sincronización en tiempo real", "Interfaz intuitiva", "Modo offline"],
    appStoreUrl: "#",
    playStoreUrl: "#",
    image: "/assets/images/app1-preview.jpg",
    rating: 4.8,
    downloads: "10K+"
  },
  {
    id: 2,
    name: "App Ejemplo 2", 
    description: "Herramienta profesional para gestionar proyectos y colaborar con tu equipo de manera eficiente.",
    category: "Negocios",
    icon: "💼",
    features: ["Gestión de tareas", "Colaboración en equipo", "Reportes detallados"],
    appStoreUrl: "#",
    playStoreUrl: "#",
    image: "/assets/images/app2-preview.jpg",
    rating: 4.6,
    downloads: "5K+"
  },
  {
    id: 3,
    name: "App Ejemplo 3",
    description: "Aplicación de entretenimiento que conecta a las personas a través de experiencias compartidas.",
    category: "Entretenimiento",
    icon: "🎮",
    features: ["Multijugador", "Chat en vivo", "Logros y recompensas"],
    appStoreUrl: "#",
    playStoreUrl: "#",
    image: "/assets/images/app3-preview.jpg",
    rating: 4.9,
    downloads: "25K+"
  }
];
---

<Layout>
	<main class="min-h-screen bg-gradient-to-br from-blue-50 to-indigo-50 dark:from-gray-900 dark:to-gray-800">
		<!-- Hero Section -->
		<section class="relative bg-gradient-to-r from-blue-600 to-indigo-700 text-white py-20 pt-32">
			<div class="container mx-auto px-4">
				<div class="max-w-4xl mx-auto text-center">
					<div class="w-20 h-20 bg-white/20 rounded-2xl flex items-center justify-center mx-auto mb-8">
						<svg class="w-10 h-10 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
							<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 18h.01M8 21h8a2 2 0 002-2V5a2 2 0 00-2-2H8a2 2 0 00-2 2v14a2 2 0 002 2z"></path>
						</svg>
					</div>
					<h1 class="text-5xl md:text-6xl font-bold mb-6">
						Productos Digitales
					</h1>
					<p class="text-xl md:text-2xl mb-8 opacity-90">
						Descubre nuestras aplicaciones desarrolladas, disponibles en App Store y Google Play Store.
					</p>
					<div class="flex flex-col sm:flex-row gap-4 justify-center">
						<a href="#apps" 
						   class="bg-white text-blue-600 px-8 py-4 rounded-xl font-semibold hover:bg-gray-100 transition-colors duration-300">
							Ver Aplicaciones
						</a>
						<a href="mailto:nitidacrea@gmail.com?subject=Consulta%20sobre%20productos%20digitales&body=Hola%2C%20me%20gustar%C3%ADa%20conocer%20m%C3%A1s%20sobre%20sus%20productos%20digitales%20y%20aplicaciones." 
						   class="border-2 border-white text-white px-8 py-4 rounded-xl font-semibold hover:bg-white hover:text-blue-600 transition-colors duration-300">
							Contactar
						</a>
					</div>
				</div>
			</div>
		</section>

		<!-- Apps Catalog Section -->
		<section id="apps" class="py-20">
			<div class="container mx-auto px-4">
				<div class="text-center mb-16">
					<h2 class="text-4xl font-bold text-gray-900 dark:text-white mb-4">
						Nuestras Aplicaciones
					</h2>
					<p class="text-xl text-gray-600 dark:text-gray-300 max-w-2xl mx-auto">
						Aplicaciones móviles desarrolladas por nuestro equipo, disponibles en las principales tiendas digitales
					</p>
				</div>

				<div class="grid md:grid-cols-2 lg:grid-cols-3 gap-8">
					{apps.map((app) => (
						<div class="bg-white dark:bg-gray-800 rounded-2xl shadow-lg hover:shadow-xl transition-all duration-300 overflow-hidden group">
							<!-- App Image -->
							<div class="h-48 bg-gradient-to-br from-blue-100 to-indigo-100 dark:from-blue-900 dark:to-indigo-900 flex items-center justify-center">
								<div class="text-6xl">{app.icon}</div>
							</div>
							
							<div class="p-6">
								<!-- Category Badge -->
								<div class="inline-flex items-center px-3 py-1 bg-blue-100 dark:bg-blue-900 text-blue-800 dark:text-blue-200 rounded-full text-sm font-medium mb-3">
									{app.category}
								</div>
								
								<!-- App Name -->
								<h3 class="text-xl font-bold text-gray-900 dark:text-white mb-2">
									{app.name}
								</h3>
								
								<!-- Description -->
								<p class="text-gray-600 dark:text-gray-300 mb-4 text-sm leading-relaxed">
									{app.description}
								</p>
								
								<!-- Features -->
								<ul class="space-y-1 mb-4">
									{app.features.map((feature) => (
										<li class="flex items-center text-sm text-gray-600 dark:text-gray-300">
											<svg class="w-4 h-4 text-green-500 mr-2" fill="currentColor" viewBox="0 0 20 20">
												<path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"></path>
											</svg>
											{feature}
										</li>
									))}
								</ul>
								
								<!-- Stats -->
								<div class="flex items-center justify-between mb-4 text-sm text-gray-500 dark:text-gray-400">
									<div class="flex items-center">
										<svg class="w-4 h-4 text-yellow-500 mr-1" fill="currentColor" viewBox="0 0 20 20">
											<path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"></path>
										</svg>
										{app.rating}
									</div>
									<div>{app.downloads} descargas</div>
								</div>
								
								<!-- Download Buttons -->
								<div class="flex gap-2">
									<a href={app.appStoreUrl} 
									   class="flex-1 bg-black hover:bg-gray-800 text-white px-4 py-2 rounded-lg text-sm font-medium transition-colors duration-300 flex items-center justify-center">
										<svg class="w-4 h-4 mr-2" fill="currentColor" viewBox="0 0 24 24">
											<path d="M18.71 19.5c-.83 1.24-1.71 2.45-3.05 2.47-1.34.03-1.77-.79-3.29-.79-1.53 0-2 .77-3.27.82-1.31.05-2.3-1.32-3.14-2.53C4.25 17 2.94 12.45 4.7 9.39c.87-1.52 2.43-2.48 4.12-2.51 1.28-.02 2.5.87 3.29.87.78 0 2.26-1.07 3.81-.91.65.03 2.47.26 3.64 1.98-.09.06-2.17 1.28-2.15 3.81.03 3.02 2.65 4.03 2.68 4.04-.03.07-.42 1.44-1.38 2.83M13 3.5c.73-.83 1.94-1.46 2.94-1.5.13 1.17-.34 2.35-1.04 3.19-.69.85-1.83 1.51-2.95 1.42-.15-1.15.41-2.35 1.05-3.11z"/>
										</svg>
										App Store
									</a>
									<a href={app.playStoreUrl} 
									   class="flex-1 bg-green-600 hover:bg-green-700 text-white px-4 py-2 rounded-lg text-sm font-medium transition-colors duration-300 flex items-center justify-center">
										<svg class="w-4 h-4 mr-2" fill="currentColor" viewBox="0 0 24 24">
											<path d="M3,20.5V3.5C3,2.91 3.34,2.39 3.84,2.15L13.69,12L3.84,21.85C3.34,21.6 3,21.09 3,20.5M16.81,15.12L6.05,21.34L14.54,12.85L16.81,15.12M20.16,10.81C20.5,11.08 20.75,11.5 20.75,12C20.75,12.5 20.53,12.9 20.18,13.18L17.89,14.5L15.39,12L17.89,9.5L20.16,10.81M6.05,2.66L16.81,8.88L14.54,11.15L6.05,2.66Z"/>
										</svg>
										Play Store
									</a>
								</div>
							</div>
						</div>
					))}
				</div>
			</div>
		</section>

		<!-- Features Section -->
		<section class="py-20">
			<div class="container mx-auto px-4">
				<div class="text-center mb-16">
					<div class="inline-flex items-center px-4 py-2 bg-blue-100 dark:bg-blue-900 text-blue-800 dark:text-blue-200 rounded-full text-sm font-medium mb-4">
						Características
					</div>
					<h2 class="text-4xl font-bold text-gray-900 dark:text-white mb-4">
						¿Por qué Nuestras Apps?
					</h2>
					<p class="text-xl text-gray-600 dark:text-gray-300 max-w-2xl mx-auto">
						Desarrollamos aplicaciones con los más altos estándares de calidad y experiencia de usuario
					</p>
				</div>

				<div class="grid md:grid-cols-2 lg:grid-cols-4 gap-8">
					<div class="bg-white dark:bg-gray-800 rounded-2xl p-8 shadow-lg hover:shadow-xl transition-all duration-300 text-center group">
						<div class="w-16 h-16 bg-blue-100 dark:bg-blue-900 rounded-2xl flex items-center justify-center mx-auto mb-6 group-hover:scale-110 transition-transform duration-300">
							<span class="text-2xl">🎨</span>
						</div>
						<h3 class="text-xl font-bold text-gray-900 dark:text-white mb-4">Diseño Excepcional</h3>
						<p class="text-gray-600 dark:text-gray-300 text-sm leading-relaxed">Interfaces intuitivas y atractivas que deleitan a los usuarios.</p>
					</div>
					<div class="bg-white dark:bg-gray-800 rounded-2xl p-8 shadow-lg hover:shadow-xl transition-all duration-300 text-center group">
						<div class="w-16 h-16 bg-blue-100 dark:bg-blue-900 rounded-2xl flex items-center justify-center mx-auto mb-6 group-hover:scale-110 transition-transform duration-300">
							<span class="text-2xl">⚡</span>
						</div>
						<h3 class="text-xl font-bold text-gray-900 dark:text-white mb-4">Rendimiento Óptimo</h3>
						<p class="text-gray-600 dark:text-gray-300 text-sm leading-relaxed">Aplicaciones rápidas y eficientes en todos los dispositivos.</p>
					</div>
					<div class="bg-white dark:bg-gray-800 rounded-2xl p-8 shadow-lg hover:shadow-xl transition-all duration-300 text-center group">
						<div class="w-16 h-16 bg-blue-100 dark:bg-blue-900 rounded-2xl flex items-center justify-center mx-auto mb-6 group-hover:scale-110 transition-transform duration-300">
							<span class="text-2xl">🔒</span>
						</div>
						<h3 class="text-xl font-bold text-gray-900 dark:text-white mb-4">Seguridad Avanzada</h3>
						<p class="text-gray-600 dark:text-gray-300 text-sm leading-relaxed">Protección de datos y privacidad de los usuarios garantizada.</p>
					</div>
					<div class="bg-white dark:bg-gray-800 rounded-2xl p-8 shadow-lg hover:shadow-xl transition-all duration-300 text-center group">
						<div class="w-16 h-16 bg-blue-100 dark:bg-blue-900 rounded-2xl flex items-center justify-center mx-auto mb-6 group-hover:scale-110 transition-transform duration-300">
							<span class="text-2xl">🔄</span>
						</div>
						<h3 class="text-xl font-bold text-gray-900 dark:text-white mb-4">Actualizaciones Constantes</h3>
						<p class="text-gray-600 dark:text-gray-300 text-sm leading-relaxed">Mejoras continuas basadas en feedback de usuarios.</p>
					</div>
				</div>
			</div>
		</section>

		<!-- CTA Section -->
		<section class="py-20 bg-gradient-to-r from-blue-600 to-indigo-700 text-white">
			<div class="container mx-auto px-4 text-center">
				<div class="max-w-4xl mx-auto">
					<div class="inline-flex items-center px-4 py-2 bg-white/20 backdrop-blur-sm text-white rounded-full text-sm font-medium mb-6">
						¡Descarga Ahora!
					</div>
					<h2 class="text-4xl md:text-5xl font-bold mb-6">
						¿Interesado en Nuestros Productos?
					</h2>
					<p class="text-xl mb-10 max-w-2xl mx-auto opacity-90">
						Contáctanos para conocer más sobre nuestras aplicaciones o para discutir un proyecto personalizado.
					</p>
					<div class="flex flex-col sm:flex-row gap-4 justify-center">
						<a href="mailto:nitidacrea@gmail.com?subject=Consulta%20sobre%20productos%20digitales&body=Hola%2C%20me%20gustar%C3%ADa%20conocer%20m%C3%A1s%20sobre%20sus%20productos%20digitales%20y%20aplicaciones." 
						   class="bg-white text-blue-600 px-8 py-4 rounded-xl font-semibold hover:bg-gray-100 transition-all duration-300 transform hover:scale-105 shadow-lg">
							Contactar Ahora
						</a>
						<a href="/branding" 
						   class="border-2 border-white text-white px-8 py-4 rounded-xl font-semibold hover:bg-white hover:text-blue-600 transition-all duration-300 transform hover:scale-105">
							Ver Diseño Digital
						</a>
					</div>
				</div>
			</div>
		</section>
	</main>

	<Contact client:load />
	<Footer client:load />
</Layout>
