---
import Benefits from '../components/Benefits.astro';
import Contact from '../components/Contact.astro';
import Faqs from '../components/Faqs.astro';
import Footer from '../components/Footer.astro';
import Gallery from '../components/Gallery.astro';
import How from '../components/How.astro';
import Individual from '../components/Individual.astro';
import Princing from '../components/Princing.astro';
import Services from '../components/Services.astro';
import Specialist from '../components/Specialist.astro';
import Layout from '../layouts/Layout.astro';
---

<Layout>
	<main class="min-h-screen bg-gradient-to-br from-purple-50 to-pink-50 dark:from-gray-900 dark:to-gray-800">
		<!-- Hero Section -->
		<section class="relative bg-gradient-to-r from-purple-600 to-pink-600 text-white py-20 pt-32">
			<div class="container mx-auto px-4">
				<div class="max-w-4xl mx-auto text-center">
					<div class="w-20 h-20 bg-white/20 rounded-2xl flex items-center justify-center mx-auto mb-8">
						<svg class="w-10 h-10 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
							<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M7 21a4 4 0 01-4-4V5a2 2 0 012-2h4a2 2 0 012 2v12a4 4 0 01-4 4zM21 5a2 2 0 00-2-2h-4a2 2 0 00-2 2v12a4 4 0 004 4h4a2 2 0 002-2V5z"></path>
						</svg>
					</div>
					<h1 class="text-5xl md:text-6xl font-bold mb-6">
						Diseño Digital
					</h1>
					<p class="text-xl md:text-2xl mb-8 opacity-90">
						Identidad visual completa, diseño gráfico profesional, páginas web y estrategia de marca adaptada a las necesidades de tu proyecto.
					</p>
					<div class="flex flex-col sm:flex-row gap-4 justify-center">
						<a href="mailto:nitidacrea@gmail.com?subject=Solicitud%20para%20agendar%20una%20llamada&body=Hola%2C%20me%20gustar%C3%ADa%20agendar%20una%20llamada%20para%20conocer%20m%C3%A1s%20sobre%20sus%20servicios%20de%20dise%C3%B1o%20y%20branding.%20%C2%BFCu%C3%A1ndo%20podr%C3%ADamos%20agendarla%3F%20Gracias." 
						   class="bg-white text-purple-600 px-8 py-4 rounded-xl font-semibold hover:bg-gray-100 transition-colors duration-300">
							Agendar Consulta Gratuita
						</a>
						<a href="/branding/proyectos" 
						   class="border-2 border-white text-white px-8 py-4 rounded-xl font-semibold hover:bg-white hover:text-purple-600 transition-colors duration-300">
							Ver Proyectos
						</a>
					</div>
				</div>
			</div>
		</section>

		<!-- Services Section -->
		<section class="py-20">
			<div class="container mx-auto px-4">
				<div class="text-center mb-16">
					<h2 class="text-4xl font-bold text-gray-900 dark:text-white mb-4">
						Nuestros Servicios de Diseño Digital
					</h2>
					<p class="text-xl text-gray-600 dark:text-gray-300 max-w-2xl mx-auto">
						Ofrecemos soluciones creativas completas para construir una identidad de marca memorable y presencia digital
					</p>
				</div>

				<div class="grid md:grid-cols-2 lg:grid-cols-3 gap-8">
					<!-- Brand Identity -->
					<div class="bg-white dark:bg-gray-800 rounded-2xl p-8 shadow-lg hover:shadow-xl transition-shadow duration-300">
						<div class="w-16 h-16 bg-purple-100 dark:bg-purple-900 rounded-xl flex items-center justify-center mb-6">
							<svg class="w-8 h-8 text-purple-600 dark:text-purple-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
								<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M7 21a4 4 0 01-4-4V5a2 2 0 012-2h4a2 2 0 012 2v12a4 4 0 01-4 4zM21 5a2 2 0 00-2-2h-4a2 2 0 00-2 2v12a4 4 0 004 4h4a2 2 0 002-2V5z"></path>
							</svg>
						</div>
						<h3 class="text-xl font-bold text-gray-900 dark:text-white mb-4">
							Identidad Visual
						</h3>
						<p class="text-gray-600 dark:text-gray-300 mb-4">
							Creamos una identidad visual única y coherente que refleje los valores y personalidad de tu marca.
						</p>
						<ul class="space-y-2 text-sm text-gray-600 dark:text-gray-300">
							<li>• Logotipo y símbolos</li>
							<li>• Paleta de colores</li>
							<li>• Tipografías corporativas</li>
						</ul>
					</div>

					<!-- Web Design -->
					<div class="bg-white dark:bg-gray-800 rounded-2xl p-8 shadow-lg hover:shadow-xl transition-shadow duration-300">
						<div class="w-16 h-16 bg-blue-100 dark:bg-blue-900 rounded-xl flex items-center justify-center mb-6">
							<svg class="w-8 h-8 text-blue-600 dark:text-blue-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
								<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9.75 17L9 20l-1 1h8l-1-1-.75-3M3 13h18M5 17h14a2 2 0 002-2V5a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"></path>
							</svg>
						</div>
						<h3 class="text-xl font-bold text-gray-900 dark:text-white mb-4">
							Páginas Web
						</h3>
						<p class="text-gray-600 dark:text-gray-300 mb-4">
							Diseñamos sitios web modernos, responsivos y optimizados que reflejan la identidad de tu marca.
						</p>
						<ul class="space-y-2 text-sm text-gray-600 dark:text-gray-300">
							<li>• Diseño responsivo</li>
							<li>• Optimización SEO</li>
							<li>• Experiencia de usuario</li>
						</ul>
					</div>

					<!-- Graphic Design -->
					<div class="bg-white dark:bg-gray-800 rounded-2xl p-8 shadow-lg hover:shadow-xl transition-shadow duration-300">
						<div class="w-16 h-16 bg-pink-100 dark:bg-pink-900 rounded-xl flex items-center justify-center mb-6">
							<svg class="w-8 h-8 text-pink-600 dark:text-pink-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
								<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="m6.08169 15.9817 1.57292-4m-1.57292 4h-1.1m1.1 0h1.65m-.07708-4 2.72499-6.92967c.0368-.09379.1673-.09379.2042 0l2.725 6.92967m-5.65419 0h-.00607m.00607 0h5.65419m0 0 .6169 1.569m5.1104 4.453c0 1.1025-.8543 1.9963-1.908 1.9963s-1.908-.8938-1.908-1.9963c0-1.1026 1.908-4.1275 1.908-4.1275s1.908 3.0249 1.908 4.1275Z"></path>
							</svg>
						</div>
						<h3 class="text-xl font-bold text-gray-900 dark:text-white mb-4">
							Diseño Gráfico
						</h3>
						<p class="text-gray-600 dark:text-gray-300 mb-4">
							Diseñamos materiales gráficos profesionales que comunican efectivamente tu mensaje.
						</p>
						<ul class="space-y-2 text-sm text-gray-600 dark:text-gray-300">
							<li>• Materiales impresos</li>
							<li>• Diseño digital</li>
							<li>• Ilustraciones personalizadas</li>
						</ul>
					</div>
				</div>
			</div>
		</section>

		<!-- Process Section -->
		<section class="py-20 bg-gray-50 dark:bg-gray-900">
			<div class="container mx-auto px-4">
				<div class="text-center mb-16">
					<h2 class="text-4xl font-bold text-gray-900 dark:text-white mb-4">
						Nuestro Proceso Creativo
					</h2>
					<p class="text-xl text-gray-600 dark:text-gray-300 max-w-2xl mx-auto">
						Trabajamos de manera colaborativa para crear una identidad de marca que realmente represente tu visión
					</p>
				</div>

				<div class="grid md:grid-cols-2 lg:grid-cols-4 gap-8">
					<div class="text-center">
						<div class="w-16 h-16 bg-purple-600 text-white rounded-full flex items-center justify-center text-2xl font-bold mx-auto mb-4">1</div>
						<h3 class="text-xl font-bold text-gray-900 dark:text-white mb-2">Descubrimiento</h3>
						<p class="text-gray-600 dark:text-gray-300">Conocemos tu marca, valores y objetivos para crear una identidad auténtica.</p>
					</div>
					<div class="text-center">
						<div class="w-16 h-16 bg-purple-600 text-white rounded-full flex items-center justify-center text-2xl font-bold mx-auto mb-4">2</div>
						<h3 class="text-xl font-bold text-gray-900 dark:text-white mb-2">Conceptualización</h3>
						<p class="text-gray-600 dark:text-gray-300">Desarrollamos conceptos creativos y estrategias de diseño únicas.</p>
					</div>
					<div class="text-center">
						<div class="w-16 h-16 bg-purple-600 text-white rounded-full flex items-center justify-center text-2xl font-bold mx-auto mb-4">3</div>
						<h3 class="text-xl font-bold text-gray-900 dark:text-white mb-2">Diseño</h3>
						<p class="text-gray-600 dark:text-gray-300">Creamos y refinamos los elementos visuales de tu identidad de marca.</p>
					</div>
					<div class="text-center">
						<div class="w-16 h-16 bg-purple-600 text-white rounded-full flex items-center justify-center text-2xl font-bold mx-auto mb-4">4</div>
						<h3 class="text-xl font-bold text-gray-900 dark:text-white mb-2">Implementación</h3>
						<p class="text-gray-600 dark:text-gray-300">Entregamos tu nueva identidad con guías completas para su uso.</p>
					</div>
				</div>
			</div>
		</section>

		<!-- Gallery Section -->
		<section class="py-20">
			<div class="container mx-auto px-4">
				<div class="text-center mb-16">
					<h2 class="text-4xl font-bold text-gray-900 dark:text-white mb-4">
						Nuestros Proyectos
					</h2>
					<p class="text-xl text-gray-600 dark:text-gray-300 max-w-2xl mx-auto">
						Descubre algunos de nuestros trabajos más recientes en diseño y branding
					</p>
				</div>
				<div class="text-center mb-8">
					<a href="/branding/proyectos" class="inline-flex items-center px-6 py-3 bg-purple-600 hover:bg-purple-700 text-white font-semibold rounded-xl transition-colors duration-300">
						<svg class="w-5 h-5 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
							<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"></path>
							<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z"></path>
						</svg>
						Ver Todos los Proyectos
					</a>
				</div>
				<Gallery client:load />
			</div>
		</section>

		<!-- Additional Sections -->
		<How client:load />
		<Benefits client:load />
		<Services client:load />
		<Princing client:load />
		<Individual client:load />
		<Specialist client:load />
		<Faqs client:load />

		<!-- CTA Section -->
		<section class="py-20 bg-purple-600 text-white">
			<div class="container mx-auto px-4 text-center">
				<h2 class="text-4xl font-bold mb-4">
					¿Listo para Crear una Marca Memorable?
				</h2>
				<p class="text-xl mb-8 opacity-90 max-w-2xl mx-auto">
					Contáctanos para una consulta gratuita y descubre cómo podemos transformar tu visión en una identidad de marca poderosa.
				</p>
				<div class="flex flex-col sm:flex-row gap-4 justify-center">
					<a href="mailto:nitidacrea@gmail.com?subject=Consulta%20sobre%20dise%C3%B1o%20y%20branding&body=Hola%2C%20me%20gustar%C3%ADa%20agendar%20una%20consulta%20para%20discutir%20mi%20proyecto%20de%20dise%C3%B1o%20y%20branding." 
					   class="bg-white text-purple-600 px-8 py-4 rounded-xl font-semibold hover:bg-gray-100 transition-colors duration-300">
						Agendar Consulta Gratuita
					</a>
					<a href="/desarrollo" 
					   class="border-2 border-white text-white px-8 py-4 rounded-xl font-semibold hover:bg-white hover:text-purple-600 transition-colors duration-300">
						Ver Desarrollo de Software
					</a>
				</div>
			</div>
		</section>
	</main>

	<Contact client:load />
	<Footer client:load />
</Layout>
