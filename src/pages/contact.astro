---
import Footer from '../components/Footer.astro';
import Navbar from '../components/Navbar.astro';
import Button from '../components/shared/Button.astro';
import Welcome from '../components/Welcome.astro';
import Layout from '../layouts/Layout.astro';

const pageTitle = "Contacto - Agenda una llamada | Nítida Digital";
const pageDescription = "Agenda una llamada de 15 minutos para conocer más sobre nuestros servicios de diseño y desarrollo web. Estamos listos para impulsar tu negocio.";
const pageUrl = "https://nitidadigital.com/contact";
const imageUrl = "https://nitidadigital.com/assets/images/og_image.png";
---

<Layout pageTitle={pageTitle} pageDescription={pageDescription} pageUrl={pageUrl} imageUrl={imageUrl}>
	<Navbar currentPath="/contact" />
	
	<Welcome 
		type="color"
		color="bg-gradient-to-r from-gray-900 via-black to-gray-800"
		title="Hablemos sobre tu próximo proyecto"
		subtitle="Agendemos una llamada de 15 minutos para conocernos, resolver tus dudas y ver cómo podemos trabajar juntos."
		primaryButton="Agendar una llamada"
		primaryLink="mailto:nitidacrea@gmail.com?subject=Solicitud%20para%20agendar%20una%20llamada&body=Hola%2C%20me%20gustar%C3%ADa%20agendar%20una%20llamada%20para%20conocer%20m%C3%A1s%20sobre%20sus%20servicios.%20%C2%BFCu%C3%A1ndo%20podr%C3%ADamos%20agendarla%3F%20Gracias."
		secondaryButton="Ver servicios"
		secondaryLink="/services"
		mediaVariant="logo"
	/>

	<!-- Formas de contacto -->
	<section class="py-16 md:py-24 bg-white">
		<div class="max-w-6xl mx-auto px-4">
			<div class="text-center mb-12" data-aos="fade-up" data-aos-delay="100">
				<h2 class="text-3xl md:text-5xl font-main text-gray-900 my-2">¿Cómo podemos ayudarte?</h2>
				<p class="text-lg text-accent max-w-3xl mx-auto">
					Elige la forma que prefieras para contactarnos. Estamos listos para responder tus preguntas y ayudarte a impulsar tu negocio.
				</p>
			</div>

			<div class="grid md:grid-cols-2 gap-8 mb-12 max-w-4xl mx-auto">
				<!-- WhatsApp -->
				<div class="bg-white rounded-2xl p-8 border border-gray-200 shadow-sm hover:shadow-md transition-shadow duration-300 text-center" data-aos="fade-up" data-aos-delay="150">
					<div class="w-16 h-16 bg-green-100 rounded-xl flex items-center justify-center mx-auto mb-6">
						<svg class="w-8 h-8 text-green-600" fill="currentColor" viewBox="0 0 24 24">
							<path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413Z"/>
						</svg>
					</div>
					<h3 class="text-2xl font-bold text-gray-900 mb-3">WhatsApp</h3>
					<p class="text-gray-600 mb-6 text-sm">
						Respuesta rápida y directa. Escríbenos y te responderemos en menos de 2 horas.
					</p>
					<a 
						href="https://wa.me/521234567890?text=Hola%2C%20me%20gustar%C3%ADa%20conocer%20m%C3%A1s%20sobre%20sus%20servicios"
						target="_blank"
						rel="noopener noreferrer"
						class="block w-full bg-green-600 text-white font-semibold py-3 px-6 rounded-xl text-center hover:bg-green-700 transition-colors"
					>
						Enviar mensaje
					</a>
				</div>

				<!-- Email -->
				<div class="bg-white rounded-2xl p-8 border border-gray-200 shadow-sm hover:shadow-md transition-shadow duration-300 text-center" data-aos="fade-up" data-aos-delay="200">
					<div class="w-16 h-16 bg-gray-100 rounded-xl flex items-center justify-center mx-auto mb-6">
						<svg class="w-8 h-8 text-gray-900" fill="none" stroke="currentColor" viewBox="0 0 24 24">
							<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"></path>
						</svg>
					</div>
					<h3 class="text-2xl font-bold text-gray-900 mb-3">Email</h3>
					<p class="text-gray-600 mb-6 text-sm">
						Para consultas detalladas o propuestas formales. Te responderemos en menos de 24 horas.
					</p>
					<a 
						href="mailto:nitidacrea@gmail.com?subject=Consulta%20desde%20web&body=Hola%2C%20me%20gustar%C3%ADa%20conocer%20m%C3%A1s%20sobre%20sus%20servicios.%20Gracias."
						class="block w-full bg-gray-900 text-white font-semibold py-3 px-6 rounded-xl text-center hover:bg-black transition-colors"
					>
						Enviar email
					</a>
				</div>
			</div>

			<!-- Opción de llamada (secundaria) -->
			<div class="text-center max-w-2xl mx-auto" data-aos="fade-up" data-aos-delay="250">
				<p class="text-gray-600 mb-4">¿Prefieres una llamada? Escríbenos por WhatsApp para coordinar.</p>
			</div>
		</div>
	</section>

	<!-- Información adicional -->
	<section class="py-16 md:py-24 bg-slate-50">
		<div class="max-w-6xl mx-auto px-4">
			<div class="bg-white rounded-2xl p-8 md:p-12 border border-gray-200 shadow-sm" data-aos="fade-up" data-aos-delay="100">
				<div class="text-center mb-8">
					<h2 class="text-3xl md:text-4xl font-main text-gray-900 mb-4">¿Qué esperar en la primera llamada?</h2>
					<p class="text-lg text-accent max-w-2xl mx-auto">
						Una conversación de 15 minutos donde entenderemos tus necesidades y te mostraremos cómo podemos ayudarte.
					</p>
				</div>

				<div class="grid md:grid-cols-2 gap-8">
					<div>
						<h3 class="text-xl font-bold text-gray-900 mb-4">Hablaremos sobre:</h3>
						<ul class="space-y-3">
							<li class="flex items-start">
								<svg class="w-5 h-5 text-green-500 mr-3 mt-1 flex-shrink-0" fill="currentColor" viewBox="0 0 20 20">
									<path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"></path>
								</svg>
								<span class="text-gray-700">Tu negocio y objetivos</span>
							</li>
							<li class="flex items-start">
								<svg class="w-5 h-5 text-green-500 mr-3 mt-1 flex-shrink-0" fill="currentColor" viewBox="0 0 20 20">
									<path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"></path>
								</svg>
								<span class="text-gray-700">Necesidades específicas de tu proyecto</span>
							</li>
							<li class="flex items-start">
								<svg class="w-5 h-5 text-green-500 mr-3 mt-1 flex-shrink-0" fill="currentColor" viewBox="0 0 20 20">
									<path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"></path>
								</svg>
								<span class="text-gray-700">Presupuesto y tiempos</span>
							</li>
							<li class="flex items-start">
								<svg class="w-5 h-5 text-green-500 mr-3 mt-1 flex-shrink-0" fill="currentColor" viewBox="0 0 20 20">
									<path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"></path>
								</svg>
								<span class="text-gray-700">Cómo trabajamos</span>
							</li>
						</ul>
					</div>
					<div>
						<h3 class="text-xl font-bold text-gray-900 mb-4">Recibirás:</h3>
						<ul class="space-y-3">
							<li class="flex items-start">
								<svg class="w-5 h-5 text-green-500 mr-3 mt-1 flex-shrink-0" fill="currentColor" viewBox="0 0 20 20">
									<path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"></path>
								</svg>
								<span class="text-gray-700">Recomendaciones personalizadas</span>
							</li>
							<li class="flex items-start">
								<svg class="w-5 h-5 text-green-500 mr-3 mt-1 flex-shrink-0" fill="currentColor" viewBox="0 0 20 20">
									<path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"></path>
								</svg>
								<span class="text-gray-700">Cotización inicial sin compromiso</span>
							</li>
							<li class="flex items-start">
								<svg class="w-5 h-5 text-green-500 mr-3 mt-1 flex-shrink-0" fill="currentColor" viewBox="0 0 20 20">
									<path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"></path>
								</svg>
								<span class="text-gray-700">Respuestas a todas tus preguntas</span>
							</li>
							<li class="flex items-start">
								<svg class="w-5 h-5 text-green-500 mr-3 mt-1 flex-shrink-0" fill="currentColor" viewBox="0 0 20 20">
									<path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"></path>
								</svg>
								<span class="text-gray-700">Información sobre nuestro proceso</span>
							</li>
						</ul>
					</div>
				</div>

				<div class="mt-12 text-center">
					<Button 
						href="mailto:nitidacrea@gmail.com?subject=Solicitud%20para%20agendar%20una%20llamada&body=Hola%2C%20me%20gustar%C3%ADa%20agendar%20una%20llamada%20para%20conocer%20m%C3%A1s%20sobre%20sus%20servicios.%20%C2%BFCu%C3%A1ndo%20podr%C3%ADamos%20agendarla%3F%20Gracias." 
						label="Agendar llamada ahora" 
						variant="primary" 
					/>
				</div>
			</div>
		</div>
	</section>

	<Footer />
</Layout>
