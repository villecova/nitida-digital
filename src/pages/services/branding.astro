---
import { getCollection } from 'astro:content';
import Footer from '../../components/Footer.astro';
import Navbar from '../../components/Navbar.astro';
import Button from '../../components/shared/Button.astro';
import ExpandGallery from '../../components/shared/ExpandGallery.svelte';
import Welcome from '../../components/Welcome.astro';
import Layout from '../../layouts/Layout.astro';

const pageTitle = "Branding & Graphic Design - Identidad Visual Profesional | Nítida Digital";
const pageDescription = "Creamos identidades visuales que ayudan a las marcas a verse consistentes, profesionales y reconocibles. Branding estratégico y diseño gráfico.";
const pageUrl = "https://nitidadigital.com/services/branding";
const imageUrl = "https://nitidadigital.com/assets/images/og_image.png";

// Filtrar proyectos de branding (todo lo que NO es web)
const allEntries = await getCollection('work');
const brandingProjects = allEntries.filter(entry => {
  const scope = entry.data.scope?.toLowerCase() || '';
  return !scope.includes('página web') && !scope.includes('web') && !scope.includes('sitio');
});

const projects = brandingProjects.map((entry) => ({
  slug: entry.slug,
  title: entry.data.title,
  gallery: entry.data.gallery
}));
---

<Layout pageTitle={pageTitle} pageDescription={pageDescription} pageUrl={pageUrl} imageUrl={imageUrl}>
	<Navbar currentPath="/services/branding" />
	
	<Welcome 
		type="color"
		color="bg-gradient-to-r from-purple-900 via-purple-800 to-purple-700"
		title="Branding & Graphic Design"
		subtitle="Identidades visuales coherentes que generan confianza y diferencian tu marca en el mercado."
		primaryButton="Solicitar propuesta de branding"
		primaryLink="/contact"
		secondaryButton="Ver proyectos de branding"
		secondaryLink="#portafolio"
		mediaVariant="logo"
		colorScheme="purple"
	/>

	<!-- Ideal para marcas que buscan -->
	<section class="py-16 md:py-24 bg-slate-50">
		<div class="max-w-6xl mx-auto px-4">
			<div class="text-center mb-12" data-aos="fade-up" data-aos-delay="100">
				<h2 class="text-3xl md:text-5xl font-main text-gray-900 my-2">Ideal para marcas que buscan:</h2>
			</div>
			<div class="grid md:grid-cols-3 gap-8 max-w-5xl mx-auto">
				<div class="bg-white rounded-2xl p-8 border border-gray-200 shadow-sm hover:shadow-md transition-shadow duration-300" data-aos="fade-up" data-aos-delay="150">
					<div class="w-16 h-16 bg-purple-100 rounded-xl flex items-center justify-center mb-6">
						<svg class="w-8 h-8 text-purple-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
							<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"></path>
						</svg>
					</div>
					<h3 class="text-xl font-bold text-gray-900 mb-3">Identidad coherente y profesional</h3>
					<p class="text-gray-600 text-sm leading-relaxed">Una imagen visual clara que represente correctamente tu negocio.</p>
				</div>
				<div class="bg-white rounded-2xl p-8 border border-gray-200 shadow-sm hover:shadow-md transition-shadow duration-300" data-aos="fade-up" data-aos-delay="200">
					<div class="w-16 h-16 bg-purple-100 rounded-xl flex items-center justify-center mb-6">
						<svg class="w-8 h-8 text-purple-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
							<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M7 21a4 4 0 01-4-4V5a2 2 0 012-2h4a2 2 0 012 2v12a4 4 0 01-4 4zM21 5a2 2 0 00-2-2h-4a2 2 0 00-2 2v12a4 4 0 004 4h4a2 2 0 002-2V5z"></path>
						</svg>
					</div>
					<h3 class="text-xl font-bold text-gray-900 mb-3">Diferenciarse en su mercado</h3>
					<p class="text-gray-600 text-sm leading-relaxed">Una marca memorable que destaque frente a la competencia.</p>
				</div>
				<div class="bg-white rounded-2xl p-8 border border-gray-200 shadow-sm hover:shadow-md transition-shadow duration-300" data-aos="fade-up" data-aos-delay="250">
					<div class="w-16 h-16 bg-purple-100 rounded-xl flex items-center justify-center mb-6">
						<svg class="w-8 h-8 text-purple-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
							<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0zm6 3a2 2 0 11-4 0 2 2 0 014 0zM7 10a2 2 0 11-4 0 2 2 0 014 0z"></path>
						</svg>
					</div>
					<h3 class="text-xl font-bold text-gray-900 mb-3">Conexión con su audiencia</h3>
					<p class="text-gray-600 text-sm leading-relaxed">Una identidad visual que comunique valores y genere confianza.</p>
				</div>
			</div>
		</div>
	</section>

	<!-- Qué entregas -->
	<section class="py-16 md:py-24 bg-white">
		<div class="max-w-6xl mx-auto px-4">
			<div class="text-center mb-12" data-aos="fade-up" data-aos-delay="100">
				<h2 class="text-3xl md:text-5xl font-main text-gray-900 my-2">Qué obtienes con tu identidad visual</h2>
				<p class="text-lg text-gray-700 mt-4 max-w-3xl mx-auto">
					Tu marca es más que un logotipo. Una identidad visual coherente genera confianza, diferencia tu marca y comunica tu propuesta de valor de manera clara y consistente.
				</p>
			</div>

			<div class="grid md:grid-cols-2 lg:grid-cols-3 gap-8">
				<div class="bg-white rounded-2xl p-8 border border-gray-200 shadow-sm hover:shadow-md transition-shadow duration-300" data-aos="fade-up" data-aos-delay="150">
					<div class="w-16 h-16 bg-purple-100 rounded-xl flex items-center justify-center mb-6">
						<svg class="w-8 h-8 text-purple-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
							<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z"></path>
						</svg>
					</div>
					<h3 class="text-xl font-bold text-gray-900 mb-3">Logotipo y variaciones</h3>
					<p class="text-gray-600 text-sm leading-relaxed">Diseño principal con versiones para diferentes contextos y aplicaciones.</p>
				</div>
				<div class="bg-white rounded-2xl p-8 border border-gray-200 shadow-sm hover:shadow-md transition-shadow duration-300" data-aos="fade-up" data-aos-delay="200">
					<div class="w-16 h-16 bg-purple-100 rounded-xl flex items-center justify-center mb-6">
						<svg class="w-8 h-8 text-purple-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
							<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M7 21a4 4 0 01-4-4V5a2 2 0 012-2h4a2 2 0 012 2v12a4 4 0 01-4 4zM21 5a2 2 0 00-2-2h-4a2 2 0 00-2 2v12a4 4 0 004 4h4a2 2 0 002-2V5z"></path>
						</svg>
					</div>
					<h3 class="text-xl font-bold text-gray-900 mb-3">Paleta de colores</h3>
					<p class="text-gray-600 text-sm leading-relaxed">Colores principales y secundarios con códigos y guía de uso.</p>
				</div>
				<div class="bg-white rounded-2xl p-8 border border-gray-200 shadow-sm hover:shadow-md transition-shadow duration-300" data-aos="fade-up" data-aos-delay="250">
					<div class="w-16 h-16 bg-purple-100 rounded-xl flex items-center justify-center mb-6">
						<svg class="w-8 h-8 text-purple-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
							<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6.253v13m0-13C10.832 5.477 9.246 5 7.5 5S4.168 5.477 3 6.253v13C4.168 18.477 5.754 18 7.5 18s3.332.477 4.5 1.253m0-13C13.168 5.477 14.754 5 16.5 5c1.747 0 3.332.477 4.5 1.253v13C19.832 18.477 18.247 18 16.5 18c-1.746 0-3.332.477-4.5 1.253"></path>
						</svg>
					</div>
					<h3 class="text-xl font-bold text-gray-900 mb-3">Tipografía</h3>
					<p class="text-gray-600 text-sm leading-relaxed">Selección de fuentes que reflejan la personalidad de tu marca.</p>
				</div>
				<div class="bg-white rounded-2xl p-8 border border-gray-200 shadow-sm hover:shadow-md transition-shadow duration-300" data-aos="fade-up" data-aos-delay="300">
					<div class="w-16 h-16 bg-purple-100 rounded-xl flex items-center justify-center mb-6">
						<svg class="w-8 h-8 text-purple-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
							<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6.253v13m0-13C10.832 5.477 9.246 5 7.5 5S4.168 5.477 3 6.253v13C4.168 18.477 5.754 18 7.5 18s3.332.477 4.5 1.253m0-13C13.168 5.477 14.754 5 16.5 5c1.747 0 3.332.477 4.5 1.253v13C19.832 18.477 18.247 18 16.5 18c-1.746 0-3.332.477-4.5 1.253"></path>
						</svg>
					</div>
					<h3 class="text-xl font-bold text-gray-900 mb-3">Manual de marca</h3>
					<p class="text-gray-600 text-sm leading-relaxed">Guía completa para mantener la coherencia visual en todos los materiales.</p>
				</div>
				<div class="bg-white rounded-2xl p-8 border border-gray-200 shadow-sm hover:shadow-md transition-shadow duration-300" data-aos="fade-up" data-aos-delay="350">
					<div class="w-16 h-16 bg-purple-100 rounded-xl flex items-center justify-center mb-6">
						<svg class="w-8 h-8 text-purple-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
							<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M7 21h10a2 2 0 002-2V9.414a1 1 0 00-.293-.707l-5.414-5.414A1 1 0 0012.586 3H7a2 2 0 00-2 2v14a2 2 0 002 2z"></path>
						</svg>
					</div>
					<h3 class="text-xl font-bold text-gray-900 mb-3">Materiales de marketing</h3>
					<p class="text-gray-600 text-sm leading-relaxed">Diseño de materiales listos para usar: tarjetas, papelería, plantillas para redes.</p>
				</div>
				<div class="bg-white rounded-2xl p-8 border border-gray-200 shadow-sm hover:shadow-md transition-shadow duration-300" data-aos="fade-up" data-aos-delay="400">
					<div class="w-16 h-16 bg-purple-100 rounded-xl flex items-center justify-center mb-6">
						<svg class="w-8 h-8 text-purple-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
							<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 8h14M5 8a2 2 0 110-4h14a2 2 0 110 4M5 8v10a2 2 0 002 2h10a2 2 0 002-2V8m-9 4h4"></path>
						</svg>
					</div>
					<h3 class="text-xl font-bold text-gray-900 mb-3">Archivos editables</h3>
					<p class="text-gray-600 text-sm leading-relaxed">Todos los archivos en formatos editables: vectoriales, raster, impresión y web.</p>
				</div>
			</div>
		</div>
	</section>

	<!-- Proceso específico de branding -->
	<section class="py-16 md:py-24 bg-slate-50">
		<div class="max-w-6xl mx-auto px-4">
			<div class="text-center mb-12" data-aos="fade-up" data-aos-delay="100">
				<h2 class="text-3xl md:text-5xl font-main text-gray-900 my-2">Cómo trabajamos</h2>
			</div>

			<div class="grid md:grid-cols-4 gap-8">
				<div class="text-center" data-aos="fade-up" data-aos-delay="150">
					<div class="w-16 h-16 bg-white rounded-xl border border-gray-200 flex items-center justify-center mx-auto mb-4 number-bounce number-bounce-1">
						<span class="text-2xl font-bold text-purple-600">1</span>
					</div>
					<h3 class="text-xl font-semibold text-gray-900 mb-2">Brief y descubrimiento</h3>
					<p class="text-gray-600 text-sm">Entendemos tu negocio, objetivos y audiencia para crear una identidad que te represente.</p>
				</div>
				<div class="text-center" data-aos="fade-up" data-aos-delay="200">
					<div class="w-16 h-16 bg-white rounded-xl border border-gray-200 flex items-center justify-center mx-auto mb-4 number-bounce number-bounce-2">
						<span class="text-2xl font-bold text-purple-600">2</span>
					</div>
					<h3 class="text-xl font-semibold text-gray-900 mb-2">Diseño y wireframes</h3>
					<p class="text-gray-600 text-sm">Presentamos conceptos iniciales y desarrollamos la dirección visual de tu marca.</p>
				</div>
				<div class="text-center" data-aos="fade-up" data-aos-delay="250">
					<div class="w-16 h-16 bg-white rounded-xl border border-gray-200 flex items-center justify-center mx-auto mb-4 number-bounce number-bounce-3">
						<span class="text-2xl font-bold text-purple-600">3</span>
					</div>
					<h3 class="text-xl font-semibold text-gray-900 mb-2">Desarrollo y pruebas</h3>
					<p class="text-gray-600 text-sm">Iteramos y perfeccionamos el concepto elegido hasta lograr el resultado ideal.</p>
				</div>
				<div class="text-center" data-aos="fade-up" data-aos-delay="300">
					<div class="w-16 h-16 bg-white rounded-xl border border-gray-200 flex items-center justify-center mx-auto mb-4 number-bounce number-bounce-4">
						<span class="text-2xl font-bold text-purple-600">4</span>
					</div>
					<h3 class="text-xl font-semibold text-gray-900 mb-2">Lanzamiento y soporte</h3>
					<p class="text-gray-600 text-sm">Recibes todos los archivos organizados y listos para usar en todos tus materiales.</p>
				</div>
			</div>
		</div>
	</section>

	<!-- Portafolio de branding -->
	<section class="py-16 md:py-24 bg-white" id="portafolio">
		<div class="max-w-6xl mx-auto px-4">
			<div class="text-center mb-12" data-aos="fade-up" data-aos-delay="100">
				<h2 class="text-3xl md:text-5xl font-main text-gray-900 my-2">Identidades visuales que hemos creado</h2>
				<p class="text-lg text-accent mb-10">
					Ejemplos de proyectos de branding y diseño gráfico para nuestros clientes.
				</p>
			</div>

			{projects.length > 0 ? (
				<ExpandGallery client:only {projects} initialCount={6} colorScheme="purple" />
			) : (
				<div class="text-center py-12">
					<p class="text-gray-600">Próximamente: ejemplos de nuestros proyectos de branding.</p>
				</div>
			)}
		</div>
	</section>

	<!-- CTA específico -->
	<section class="py-16 md:py-24 bg-gradient-to-r from-purple-600 to-purple-800">
		<div class="max-w-4xl mx-auto px-4 text-center" data-aos="fade-up" data-aos-delay="100">
			<h2 class="text-3xl md:text-5xl font-main text-white my-2 mb-6">
				¿Listo para construir una identidad visual coherente?
			</h2>
			<Button href="/contact" label="Solicitar propuesta de branding" variant="secondary" colorScheme="purple" />
		</div>
	</section>

	<Footer />
</Layout>
