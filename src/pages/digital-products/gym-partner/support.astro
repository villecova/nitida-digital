---
import Footer from '../../../components/Footer.astro';
import Navbar from '../../../components/Navbar.astro';
import Layout from '../../../layouts/Layout.astro';

const pageTitle = "Soporte - Gym Partner | Nítida Digital";
const pageDescription = "Página de soporte para Gym Partner. Encuentra guías de uso, preguntas frecuentes y contacto de soporte para tu app de entrenamiento.";
const pageUrl = "https://nitidadigital.com/digital-products/gym-partner/support";
const imageUrl = "https://nitidadigital.com/assets/images/og_image.png";
---

<Layout pageTitle={pageTitle} pageDescription={pageDescription} pageUrl={pageUrl} imageUrl={imageUrl}>
  <Navbar currentPath="/digital-products" />

  <div class="max-w-4xl mx-auto px-4 pt-32 pb-12">
    <!-- Header -->
    <div class="text-center mb-12">
      <div class="w-32 h-32 rounded-2xl flex items-center justify-center mx-auto mb-6 bg-blue-100">
        <span class="text-6xl">💪</span>
      </div>
      <h1 class="text-4xl font-bold text-gray-900 mb-4 font-main">Soporte – Gym Partner</h1>
      <p class="text-xl text-gray-600 font-primary max-w-3xl mx-auto">
        Bienvenido a la página de soporte de <strong>Gym Partner</strong>, una app diseñada para ayudarte a llevar el control de tus entrenamientos y mantener consistencia en el gimnasio.
      </p>
    </div>

    <!-- Content -->
    <div class="prose prose-slate max-w-none">
      <!-- Guía rápida de uso -->
      <div class="bg-gray-50 rounded-2xl p-8 mb-8">
        <h2 class="text-2xl font-bold text-gray-900 mb-6 flex items-center mt-0">
          <span class="text-2xl mr-3">📘</span>
          Guía rápida de uso
        </h2>
        <div class="space-y-4">
          <div class="flex items-center">
            <div class="w-8 h-8 bg-green-500 text-white rounded-full flex items-center justify-center text-sm font-bold mr-4 flex-shrink-0">1</div>
            <div class="flex-1">
              <h3 class="font-semibold text-gray-900 mb-2 mt-0">Crea o selecciona tu rutina</h3>
              <p class="text-gray-600">Puedes crear tus propias rutinas o elegir una existente antes de comenzar tu entrenamiento.</p>
            </div>
          </div>
          <div class="flex items-center">
            <div class="w-8 h-8 bg-green-500 text-white rounded-full flex items-center justify-center text-sm font-bold mr-4 flex-shrink-0">2</div>
            <div class="flex-1">
              <h3 class="font-semibold text-gray-900 mb-2 mt-0">Registra pesos durante el entrenamiento</h3>
              <p class="text-gray-600">Durante la sesión de entrenamiento solo puedes actualizar los pesos y marcar tus series como completadas. Si necesitas modificar la rutina (ejercicios, repeticiones o estructura), deberás hacerlo fuera de la sesión, desde el detalle de la rutina.</p>
            </div>
          </div>
          <div class="flex items-center">
            <div class="w-8 h-8 bg-green-500 text-white rounded-full flex items-center justify-center text-sm font-bold mr-4 flex-shrink-0">3</div>
            <div class="flex-1">
              <h3 class="font-semibold text-gray-900 mb-2 mt-0">Usa el temporizador de descanso</h3>
              <p class="text-gray-600">Controla tus tiempos de descanso entre series con el temporizador integrado.</p>
            </div>
          </div>
          <div class="flex items-center">
            <div class="w-8 h-8 bg-green-500 text-white rounded-full flex items-center justify-center text-sm font-bold mr-4 flex-shrink-0">4</div>
            <div class="flex-1">
              <h3 class="font-semibold text-gray-900 mb-2 mt-0">Actualiza tus rutinas fuera del entrenamiento</h3>
              <p class="text-gray-600">Puedes editar tus rutinas en cualquier momento, pero durante una sesión solo podrás registrar pesos, repeticiones y marcar el progreso.</p>
            </div>
          </div>
        </div>
      </div>

      <!-- Preguntas frecuentes -->
      <div class="bg-white rounded-2xl p-8 mb-8 border border-gray-200">
        <h2 class="text-2xl font-bold text-gray-900 mb-6 flex items-center mt-0">
          <span class="text-2xl mr-3">❓</span>
          Preguntas frecuentes
        </h2>
        
        <div class="space-y-6">
          <div>
            <h3 class="font-semibold text-gray-900 mb-2">¿Necesito internet?</h3>
            <p class="text-gray-600">No. La app funciona completamente en tu dispositivo.</p>
          </div>
          
          <div>
            <h3 class="font-semibold text-gray-900 mb-2">¿Dónde se guardan mis datos?</h3>
            <p class="text-gray-600">Se almacenan localmente en tu dispositivo.</p>
          </div>
          
          <div>
            <h3 class="font-semibold text-gray-900 mb-2">¿Qué pasa si elimino la app?</h3>
            <p class="text-gray-600">Se eliminarán todos tus datos.</p>
          </div>

          <div>
            <h3 class="font-semibold text-gray-900 mb-2">¿Puedo editar mis registros?</h3>
            <p class="text-gray-600">Sí, puedes modificar pesos y repeticiones en cualquier momento.</p>
          </div>
        </div>
      </div>

      <!-- Contacto de soporte -->
      <div class="bg-gray-50 rounded-2xl p-8 mb-8">
        <h2 class="text-2xl font-bold text-gray-900 mb-4 flex items-center mt-0">
          <span class="text-2xl mr-3">🛠️</span>
          Contacto
        </h2>
        <p class="text-gray-600 mb-4">Si necesitas ayuda puedes escribir a:</p>
        <p class="text-gray-600">
          <a href="mailto:nitidacrea@gmail.com" class="no-underline text-blue-600 hover:text-blue-800">nitidacrea@gmail.com</a>
        </p>
      </div>

      <!-- Privacidad -->
      <div class="bg-gray-50 rounded-2xl p-8">
        <h2 class="text-2xl font-bold text-gray-900 mb-6 flex items-center mt-0">
          <span class="text-2xl mr-3">🔒</span>
          Privacidad
        </h2>
        <div class="space-y-4 text-gray-600">
          <p>Gym Partner no recopila datos personales ni utiliza servidores externos.</p>
          <p>Consulta nuestra <a href="/digital-products/gym-partner/privacy-policy" class="no-underline text-blue-600 hover:text-blue-800">Política de Privacidad</a> y <a href="/digital-products/gym-partner/term-gym-partner" class="no-underline text-blue-600 hover:text-blue-800">Términos y Condiciones</a>.</p>
        </div>
      </div>
    </div>
  </div>

  <Footer hideTerms={true} hideSocial={true} />
</Layout>
